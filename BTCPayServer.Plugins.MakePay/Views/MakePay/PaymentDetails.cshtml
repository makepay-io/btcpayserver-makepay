@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Data
@using BTCPayServer.Plugins.MakePay.Models
@using BTCPayServer.Services
@inject DisplayFormatter DisplayFormatter
@model MakePayPaymentDetailsViewModel
@{
    ViewData.SetActivePage("MakePayPayments", "MakePay", "MakePay Payment Details");
    var payment = Model.Payment;
}

<div class="mb-3">
    <a asp-action="Payments" asp-route-storeId="@Model.StoreId" class="text-secondary">
        &lsaquo; Back to payments
    </a>
</div>

<div class="sticky-header-setup"></div>
<div class="sticky-header d-sm-flex align-items-center justify-content-between">
    <div>
        <div class="text-uppercase text-muted small fw-semibold mb-1">Payment details</div>
        <h2 class="mb-0 d-flex align-items-center gap-2">
            <vc:truncate-center text="@(!string.IsNullOrWhiteSpace(payment.SessionId) ? payment.SessionId : payment.PaymentId)" classes="truncate-center-id" />
            <button type="button"
                    class="btn btn-link p-0 text-secondary makepay-help-button"
                    data-makepay-help-toggle="makepay-payment-details-help"
                    aria-controls="makepay-payment-details-help"
                    aria-expanded="false"
                    title="About MakePay payment details">
                <vc:icon symbol="info" />
            </button>
        </h2>
    </div>
    <span class="badge rounded-pill @StatusClass(payment.Status) mt-3 mt-sm-0">@payment.Status</span>
</div>

<div id="makepay-payment-details-help" class="makepay-page-help bg-tile rounded p-4 mb-4" data-makepay-help="makepay-payment-details-help" hidden>
    <div class="d-flex gap-3">
        <div class="flex-fill">
            <p class="mb-2">This page combines BTCPay invoice data with the MakePay session data recorded for the payment.</p>
            <p class="mb-2">The Invoice and Payment sections show reconciliation fields such as quoted pay amount, settlement amount, MakePay status, and delivery id.</p>
            <p class="mb-0">The Deposit and Transactions sections show the payer network, deposit destination, payment request, and transaction explorer links when a supported transaction id is available.</p>
        </div>
        <button type="button" class="btn-close flex-shrink-0" data-makepay-help-dismiss="makepay-payment-details-help" aria-label="Close">
            <vc:icon symbol="close" />
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <section class="border rounded p-4 h-100">
            <h3 class="h4 mb-3">Invoice</h3>
            <dl class="makepay-detail-list mb-0">
                <dt>Invoice</dt>
                <dd>
                    <a asp-controller="UIInvoice" asp-action="Invoice" asp-route-invoiceId="@payment.InvoiceId">
                        <vc:truncate-center text="@payment.InvoiceId" classes="truncate-center-id" />
                    </a>
                </dd>
                <dt>Order ID</dt>
                <dd>@ValueOrDash(payment.OrderId)</dd>
                <dt>Created</dt>
                <dd>@payment.Created.ToBrowserDate()</dd>
                <dt>BTCPay amount</dt>
                <dd data-sensitive>@DisplayFormatter.Currency(payment.Amount, payment.Currency)</dd>
                <dt>MakePay status</dt>
                <dd>@ValueOrDash(payment.MakePayStatus)</dd>
                <dt>Session</dt>
                <dd><vc:truncate-center text="@payment.SessionId" classes="truncate-center-id" /></dd>
                <dt>Payment link</dt>
                <dd><vc:truncate-center text="@payment.PaymentLinkUid" classes="truncate-center-id" /></dd>
            </dl>
        </section>
    </div>
    <div class="col-xl-6">
        <section class="border rounded p-4 h-100">
            <h3 class="h4 mb-3">Payment</h3>
            <dl class="makepay-detail-list mb-0">
                <dt>Method</dt>
                <dd>@(payment.PaymentMethod == "cash_app_onramp" ? "Cash App" : "Crypto")</dd>
                <dt>Pay asset</dt>
                <dd>@ValueOrDash(payment.SellAsset)</dd>
                <dt>Quoted pay amount</dt>
                <dd>@ValueOrDash(payment.RequiredSellAmount)</dd>
                <dt>Settlement asset</dt>
                <dd>@ValueOrDash(payment.BuyAsset ?? payment.Currency)</dd>
                <dt>Settlement amount</dt>
                <dd>@ValueOrDash(payment.SettlementAmount)</dd>
                <dt>Settlement status</dt>
                <dd>@ValueOrDash(payment.SettlementClassification)</dd>
                <dt>Delivery</dt>
                <dd><vc:truncate-center text="@payment.DeliveryId" classes="truncate-center-id" /></dd>
            </dl>
        </section>
    </div>
    <div class="col-xl-6">
        <section class="border rounded p-4 h-100">
            <h3 class="h4 mb-3">Deposit</h3>
            <dl class="makepay-detail-list mb-0">
                <dt>Network</dt>
                <dd>@ValueOrDash(payment.DepositNetwork)</dd>
                <dt>Address</dt>
                <dd><vc:truncate-center text="@payment.DepositAddress" classes="truncate-center-id" /></dd>
                <dt>Payment request</dt>
                <dd><vc:truncate-center text="@payment.PaymentRequest" classes="truncate-center-id" /></dd>
            </dl>
        </section>
    </div>
    <div class="col-xl-6">
        <section class="border rounded p-4 h-100">
            <h3 class="h4 mb-3">Transactions</h3>
            @if (Model.ExplorerLinks.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var link in Model.ExplorerLinks)
                    {
                        <a href="@link.Url" target="_blank" rel="noreferrer noopener" class="list-group-item px-0 d-flex align-items-center justify-content-between gap-3">
                            <span>
                                <span class="fw-semibold">@link.Label</span>
                                <span class="d-block small text-muted">
                                    <vc:truncate-center text="@link.TransactionId" classes="truncate-center-id" />
                                </span>
                            </span>
                            <vc:icon symbol="actions-open-in-new" />
                        </a>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(payment.TransactionIds))
            {
                <vc:truncate-center text="@payment.TransactionIds" classes="truncate-center-id" />
            }
            else
            {
                <div class="text-muted">No transaction id recorded yet.</div>
            }
        </section>
    </div>
</div>

<style>
    .makepay-detail-list {
        display: grid;
        grid-template-columns: minmax(8rem, 14rem) minmax(0, 1fr);
        gap: .75rem 1.25rem;
    }

    .makepay-detail-list dt {
        color: var(--btcpay-body-text-muted, #6c757d);
        font-weight: 400;
    }

    .makepay-detail-list dd {
        margin-bottom: 0;
        min-width: 0;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .makepay-help-button {
        line-height: 1;
        margin-left: .5rem;
    }

    .makepay-page-help[hidden] {
        display: none !important;
    }

    @@media (max-width: 575.98px) {
        .makepay-detail-list {
            grid-template-columns: 1fr;
            gap: .25rem;
        }

        .makepay-detail-list dd {
            text-align: left;
            margin-bottom: .75rem;
        }
    }
</style>

<script>
(function () {
    document.querySelectorAll('[data-makepay-help]').forEach(function (panel) {
        var key = panel.dataset.makepayHelp;
        var toggle = document.querySelector('[data-makepay-help-toggle="' + key + '"]');
        var dismiss = panel.querySelector('[data-makepay-help-dismiss="' + key + '"]');
        if (!key || !toggle || !dismiss) {
            return;
        }

        var dismissedKey = key + ':dismissed';
        function setVisible(visible) {
            panel.hidden = !visible;
            toggle.setAttribute('aria-expanded', visible ? 'true' : 'false');
        }

        setVisible(localStorage.getItem(dismissedKey) !== 'true');

        toggle.addEventListener('click', function () {
            if (panel.hidden) {
                localStorage.removeItem(dismissedKey);
                setVisible(true);
            } else {
                localStorage.setItem(dismissedKey, 'true');
                setVisible(false);
            }
        });

        dismiss.addEventListener('click', function () {
            localStorage.setItem(dismissedKey, 'true');
            setVisible(false);
        });
    });
})();
</script>

@functions {
    private static string ValueOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string StatusClass(PaymentStatus status)
    {
        return status switch
        {
            PaymentStatus.Settled => "bg-success",
            PaymentStatus.Processing => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }
}
