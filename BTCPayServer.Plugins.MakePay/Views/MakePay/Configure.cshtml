@using BTCPayServer.Abstractions.Extensions
@model BTCPayServer.Plugins.MakePay.PaymentHandler.MakePayPaymentMethodConfig
@{
    var section = ViewData["MakePaySection"]?.ToString() ?? "general";
    var activePage = ViewData["MakePayActivePage"]?.ToString() ?? "MakePayGeneral";
    var title = ViewData["MakePayTitle"]?.ToString() ?? "MakePay General";
    ViewData.SetActivePage(activePage, "MakePay", title);
    var storeId = Context.Request.RouteValues["storeId"]?.ToString();
}

<form method="post">
    <div class="sticky-header-setup"></div>
    <div class="sticky-header d-sm-flex align-items-center justify-content-between">
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <div class="d-flex gap-3 mt-3 mt-sm-0">
            @if (section == "general" && Model.IsConfigured)
            {
                <button name="command" type="submit" value="disconnect" class="btn btn-outline-danger">Disconnect</button>
            }
            <button name="command" type="submit" value="save" class="btn btn-secondary">Save</button>
            @if (section == "general")
            {
                <button name="command" type="submit" value="connect" class="btn btn-primary">Connect MakePay</button>
            }
        </div>
    </div>

    <partial name="_StatusMessage" />

    <div class="row">
        <div class="col-xl-8 col-xxl-constrain">
            @if (Model.IsConfigured)
            {
                <div class="alert alert-success">
                    <strong>Connected</strong>
                    @if (!string.IsNullOrEmpty(Model.CompanyId))
                    {
                        <div class="small mt-1">Company: <code>@Model.CompanyId</code></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.WebhookSecretLast4))
                    {
                        <div class="small">Webhook secret: <code>...@Model.WebhookSecretLast4</code></div>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.LastError))
            {
                <div class="alert alert-danger">@Model.LastError</div>
            }
            else
            {
                <div class="alert alert-info makepay-notice" role="alert" data-makepay-notice="makepay-connect-options">
                    <div class="d-flex align-items-start justify-content-between gap-3">
                        <button type="button" class="btn btn-link alert-link d-inline-flex align-items-center gap-2 p-0 text-start" data-role="makepay-notice-toggle" aria-expanded="true">
                            <vc:icon symbol="caret-down" />
                            <span class="fw-semibold">Connection options</span>
                        </button>
                        <button type="button" class="btn-close flex-shrink-0" data-role="makepay-notice-dismiss" aria-label="Close">
                            <vc:icon symbol="close" />
                        </button>
                    </div>
                    <div class="makepay-notice-body mt-2">
                        You can connect a MakePay account, or use anonymous one-time MakePay payment links after adding chain addresses below.
                    </div>
                </div>
            }

            <div class="pt-4">
                @if (section == "general")
                {
                    <div class="form-group">
                        <div class="d-flex align-items-center">
                            <input id="Enabled" name="Enabled" type="checkbox" value="true" class="btcpay-toggle me-2" @(Model.Enabled ? "checked" : null) />
                            <input name="Enabled" type="hidden" value="false" />
                            <label for="Enabled" class="form-label mb-0">Enable MakePay</label>
                        </div>
                        <span asp-validation-for="Enabled" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SiteUrl" class="form-label">BTCPay Server site URL</label>
                        <input asp-for="SiteUrl" type="url" class="form-control" autocomplete="url" />
                        <div class="form-text">
                            Used for MakePay return links and webhook delivery. Use the public HTTPS URL customers can reach.
                        </div>
                        <span asp-validation-for="SiteUrl" class="text-danger"></span>
                    </div>

                    <h4 class="mt-4 mb-3">Checkout</h4>

                    <div class="form-group">
                        <div class="d-flex align-items-center">
                            <input id="DisplayQuoteApproval" name="DisplayQuoteApproval" type="checkbox" value="true" class="btcpay-toggle me-2" @(Model.DisplayQuoteApproval ? "checked" : null) />
                            <input name="DisplayQuoteApproval" type="hidden" value="false" />
                            <label for="DisplayQuoteApproval" class="form-label mb-0">Quote approval</label>
                        </div>
                        <div class="form-text">
                            When disabled, checkout starts the payment immediately after the customer chooses a currency and network.
                        </div>
                    </div>

                    <h4 class="mt-4 mb-3">Receipts</h4>

                    <div class="form-group">
                        <div class="d-flex align-items-center">
                            <input asp-for="RequestReceiptEmailFromCustomer" type="checkbox" class="btcpay-toggle me-2" />
                            <label asp-for="RequestReceiptEmailFromCustomer" class="form-label mb-0">Ask customer for receipt email</label>
                        </div>
                        <div class="form-text">
                            When disabled, MakePay uses the default receipt email below.
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="DefaultReceiptEmail" class="form-label">Default receipt email</label>
                        <input asp-for="DefaultReceiptEmail" type="email" class="form-control" autocomplete="email" />
                        <div class="form-text">
                            Used for MakePay receipts when customer email collection is disabled.
                        </div>
                        <span asp-validation-for="DefaultReceiptEmail" class="text-danger"></span>
                    </div>

                    <h4 class="mt-5 mb-3">Refunds</h4>

                    <div class="form-group">
                        <label asp-for="RefundAddressMode" class="form-label">Refund address collection</label>
                        <select asp-for="RefundAddressMode" class="form-select">
                            <option value="@MakePayPaymentMethodConfig.RefundAddressModeMerchantWallet">Merchant wallets</option>
                            <option value="@MakePayPaymentMethodConfig.RefundAddressModePayerEntered">Ask payer</option>
                        </select>
                        <div class="form-text">
                            Merchant wallets uses saved MakePay refund wallets. Ask payer collects a refund address during checkout for assets that need one.
                        </div>
                    </div>

                    <h4 class="mt-5 mb-3">Settlement</h4>
                    <input asp-for="SettlementCurrency" type="hidden" />
                    <input asp-for="SettlementPrioritiesJson" type="hidden" />
                    <input asp-for="ChainAddressesJson" type="hidden" />
                    @if (Model.IsConfigured)
                    {
                        <input asp-for="SettlementMode" type="hidden" />
                    }
                    else
                    {
                        <div class="form-group" id="makepay-settlement-route" data-url="@Url.Action("Currencies", "MakePay", new { storeId })">
                            <label class="form-label">Settlement destination</label>
                            <div class="makepay-settlement-mode-grid">
                                <label class="makepay-settlement-mode-card border rounded p-3">
                                    <input class="form-check-input mt-1" type="radio" name="SettlementMode" value="@MakePayPaymentMethodConfig.SettlementModeBtcpay" @(Model.NormalizedSettlementMode() == MakePayPaymentMethodConfig.SettlementModeCustom ? null : "checked") />
                                    <span class="min-w-0">
                                        <span class="d-block fw-semibold">BTCPay Server</span>
                                        <span class="d-block text-muted small mt-1">Reserve a fresh BTC wallet address from this store for each invoice.</span>
                                    </span>
                                </label>
                                <label class="makepay-settlement-mode-card border rounded p-3">
                                    <input class="form-check-input mt-1" type="radio" name="SettlementMode" value="@MakePayPaymentMethodConfig.SettlementModeCustom" @(Model.NormalizedSettlementMode() == MakePayPaymentMethodConfig.SettlementModeCustom ? "checked" : null) />
                                    <span class="min-w-0">
                                        <span class="d-block fw-semibold">Custom MakePay route</span>
                                        <span class="d-block text-muted small mt-1">Settle to a saved chain address from the MakePay Settlement page.</span>
                                    </span>
                                </label>
                            </div>

                            <div id="makepay-custom-settlement-panel" class="border rounded p-3 mt-3">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label" for="makepay-settlement-currency">Currency</label>
                                        <select class="form-select" id="makepay-settlement-currency"></select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label" for="makepay-settlement-chain">Chain</label>
                                        <select class="form-select" id="makepay-settlement-chain"></select>
                                    </div>
                                </div>
                                <div class="form-text mt-3" id="makepay-settlement-route-help">
                                    Loading saved MakePay settlement routes...
                                </div>
                                <div class="mt-3">
                                    <a asp-action="Settlement" asp-route-storeId="@storeId">Manage settlement addresses</a>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="alert alert-info makepay-notice mb-0" role="alert" data-makepay-notice="makepay-settlement-summary">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <button type="button" class="btn btn-link alert-link d-inline-flex align-items-center gap-2 p-0 text-start" data-role="makepay-notice-toggle" aria-expanded="true">
                                <vc:icon symbol="caret-down" />
                                <span class="fw-semibold">Settlement routing</span>
                            </button>
                            <button type="button" class="btn-close flex-shrink-0" data-role="makepay-notice-dismiss" aria-label="Close">
                                <vc:icon symbol="close" />
                            </button>
                        </div>
                        <div class="makepay-notice-body mt-2">
                            Connected MakePay payments reserve a fresh BTC receive address from this BTCPay store for each invoice. Anonymous payments use the chain addresses configured in the Settlement tab.
                        </div>
                    </div>

                    <h4 class="mt-5 mb-3">Anonymous Checkout Policy</h4>
                    <div class="alert alert-info makepay-notice" role="alert" data-makepay-notice="makepay-anonymous-policy">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <button type="button" class="btn btn-link alert-link d-inline-flex align-items-center gap-2 p-0 text-start" data-role="makepay-notice-toggle" aria-expanded="true">
                                <vc:icon symbol="caret-down" />
                                <span class="fw-semibold">Anonymous checkout defaults</span>
                            </button>
                            <button type="button" class="btn-close flex-shrink-0" data-role="makepay-notice-dismiss" aria-label="Close">
                                <vc:icon symbol="close" />
                            </button>
                        </div>
                        <div class="makepay-notice-body mt-2">
                            These defaults are sent when the plugin creates anonymous MakePay payment links. Connected MakePay accounts continue to use the policy configured in MakePay.
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="PaymentFeePayer" class="form-label">Who pays payment fees</label>
                        <select asp-for="PaymentFeePayer" class="form-select">
                            <option value="@MakePayPaymentMethodConfig.PaymentFeePayerMerchant">Merchant</option>
                            <option value="@MakePayPaymentMethodConfig.PaymentFeePayerCustomer">Customer</option>
                        </select>
                        <div class="form-text">
                            Merchant absorbs service fees. Customer adds service fees to the checkout amount before the payer sends funds.
                        </div>
                    </div>

                    <h5 class="mt-4 mb-3">Reconciliation</h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="AllowedPaymentVariancePercent" class="form-label">Percent threshold</label>
                            <div class="input-group">
                                <input asp-for="AllowedPaymentVariancePercent" type="number" min="0" max="100" step="0.01" class="form-control" />
                                <span class="input-group-text">%</span>
                            </div>
                            <div class="form-text">Accepted variance below or above the expected payment amount.</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AllowedPaymentVarianceFixedUsd" class="form-label">Fixed threshold</label>
                            <div class="input-group">
                                <input asp-for="AllowedPaymentVarianceFixedUsd" type="number" min="0" step="0.01" class="form-control" />
                                <span class="input-group-text">USD</span>
                            </div>
                            <div class="form-text">Additional fixed USD underpayment variance.</div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MerchantSurchargePercent" class="form-label">Merchant surcharge fee</label>
                            <div class="input-group">
                                <input asp-for="MerchantSurchargePercent" type="number" min="-1" max="1" step="0.01" class="form-control" />
                                <span class="input-group-text">%</span>
                            </div>
                            <div class="form-text">Use a value from -1% to 1%.</div>
                        </div>
                    </div>
                }
                else if (section == "currencies")
                {
                    <div class="form-group">
                        <input asp-for="AllowedAssetIdentifiers" type="hidden" />
                        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                            <div>
                                <label class="form-label mb-1">Allowed currencies</label>
                                <div class="form-text mt-0">
                                    Choose which MakePay-supported pay-in currencies are available in checkout.
                                </div>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="makepay-allow-all-currencies" />
                                <label class="form-check-label" for="makepay-allow-all-currencies">Allow all</label>
                            </div>
                        </div>

                        <div id="makepay-currencies-list"
                             class="list-group"
                             data-url="@Url.Action("Currencies", "MakePay", new { storeId })">
                            <div class="list-group-item text-muted">Loading currencies...</div>
                        </div>
                        <div class="form-text">
                            With Allow all enabled, new MakePay-supported currencies are automatically available.
                        </div>
                    </div>
                }
                else if (section == "settlement")
                {
                    <input asp-for="SettlementCurrency" type="hidden" />
                    <input asp-for="SettlementPrioritiesJson" type="hidden" />
                    <input asp-for="ChainAddressesJson" type="hidden" />

                    @if (Model.IsConfigured)
                    {
                        <div class="alert alert-info makepay-notice" role="alert" data-makepay-notice="makepay-connected-settlement">
                            <div class="d-flex align-items-start justify-content-between gap-3">
                                <button type="button" class="btn btn-link alert-link d-inline-flex align-items-center gap-2 p-0 text-start" data-role="makepay-notice-toggle" aria-expanded="true">
                                    <vc:icon symbol="caret-down" />
                                    <span class="fw-semibold">Connected settlement</span>
                                </button>
                                <button type="button" class="btn-close flex-shrink-0" data-role="makepay-notice-dismiss" aria-label="Close">
                                    <vc:icon symbol="close" />
                                </button>
                            </div>
                            <div class="makepay-notice-body mt-2">
                                Settlement for connected MakePay accounts is managed in the MakePay wallet. These routes are read-only here so the plugin stays aligned with your MakePay account settings.
                            </div>
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
                            <a class="btn btn-outline-primary" href="https://www.makecrypto.io/home/wemine/wallet" target="_blank" rel="noreferrer noopener">
                                Open MakePay wallet
                            </a>
                            <span class="text-muted small">Change connected-account settlement addresses in MakePay.</span>
                        </div>
                        <div class="list-group">
                            <div class="list-group-item">
                                <div class="fw-semibold">Connected account settlement</div>
                                <div class="text-muted small">
                                    MakePay applies the wallet and settlement priorities configured for the connected company. Anonymous settlement routes below are ignored while the account is connected.
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info makepay-notice" role="alert" data-makepay-notice="makepay-anonymous-settlement">
                            <div class="d-flex align-items-start justify-content-between gap-3">
                                <button type="button" class="btn btn-link alert-link d-inline-flex align-items-center gap-2 p-0 text-start" data-role="makepay-notice-toggle" aria-expanded="true">
                                    <vc:icon symbol="caret-down" />
                                    <span class="fw-semibold">Anonymous settlement</span>
                                </button>
                                <button type="button" class="btn-close flex-shrink-0" data-role="makepay-notice-dismiss" aria-label="Close">
                                    <vc:icon symbol="close" />
                                </button>
                            </div>
                            <div class="makepay-notice-body mt-2">
                                Anonymous MakePay payment links are not attached to a MakePay workspace, so the plugin sends merchant-controlled chain addresses when it creates each invoice link. MakePay uses these addresses for merchant refund routing on the selected pay-in network; the BTC address is also used as the default anonymous settlement route.
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-3">
                            <div>
                                <label class="form-label mb-1">Chain payment addresses</label>
                                <div class="form-text mt-0">
                                    Save the wallet address your team controls for each supported pay-in chain. BTC is required for anonymous settlement.
                                </div>
                            </div>
                            <div class="d-flex flex-wrap align-items-center gap-2 small" id="makepay-chain-address-summary">
                                <span class="badge bg-light text-dark border" data-role="total">Loading chains</span>
                                <span class="badge makepay-badge-missing border" data-role="missing">0 missing</span>
                                <span class="badge makepay-badge-set border" data-role="set">0 set</span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label visually-hidden" for="makepay-chain-address-search">Search chain</label>
                            <input id="makepay-chain-address-search" type="search" class="form-control" placeholder="Search chain" autocomplete="off" />
                        </div>

                        <div id="makepay-chain-address-list"
                             class="makepay-chain-address-grid"
                             data-url="@Url.Action("Currencies", "MakePay", new { storeId })">
                            <div class="border rounded p-3 text-muted">Loading chains...</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</form>

<style>
    .makepay-chain-address-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
        gap: .75rem;
    }

    .makepay-chain-address-card {
        min-width: 0;
    }

    .makepay-settlement-mode-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
        gap: .75rem;
    }

    .makepay-settlement-mode-card {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
        cursor: pointer;
    }

    .makepay-settlement-mode-card:has(input:checked) {
        border-color: var(--btcpay-primary, #51b543) !important;
        background: rgba(81, 181, 67, .08);
    }

    .makepay-chain-logo {
        width: 2.75rem;
        height: 2.75rem;
        object-fit: cover;
    }

    .makepay-chain-logo-fallback {
        width: 2.75rem;
        height: 2.75rem;
        letter-spacing: 0;
    }

    .makepay-badge-set {
        background-color: rgba(81, 181, 67, .16) !important;
        border-color: rgba(81, 181, 67, .45) !important;
        color: #51b543 !important;
    }

    .makepay-badge-missing {
        background-color: rgba(255, 196, 61, .16) !important;
        border-color: rgba(255, 196, 61, .45) !important;
        color: #ffc43d !important;
    }

    .makepay-badge-danger {
        background-color: rgba(255, 92, 92, .16) !important;
        border-color: rgba(255, 92, 92, .45) !important;
        color: #ff6b6b !important;
    }

    .makepay-notice [data-role="makepay-notice-toggle"] {
        min-width: 0;
        color: inherit;
        text-decoration: none;
    }

    .makepay-notice [data-role="makepay-notice-toggle"]:hover,
    .makepay-notice [data-role="makepay-notice-toggle"]:focus {
        text-decoration: underline;
    }

    .makepay-notice.is-collapsed .makepay-notice-body {
        display: none;
    }

    .makepay-notice.is-collapsed [data-role="makepay-notice-toggle"] .icon {
        transform: rotate(-90deg);
    }

    .makepay-notice [data-role="makepay-notice-toggle"] .icon {
        transition: transform .15s ease-in-out;
    }
</style>

<script>
(function () {
    document.querySelectorAll('[data-makepay-notice]').forEach(function (notice) {
        var key = notice.dataset.makepayNotice;
        var toggle = notice.querySelector('[data-role="makepay-notice-toggle"]');
        var dismiss = notice.querySelector('[data-role="makepay-notice-dismiss"]');
        if (!key || !toggle || !dismiss) {
            return;
        }

        var collapsedKey = key + ':collapsed';
        var dismissedKey = key + ':dismissed';

        if (localStorage.getItem(dismissedKey) === 'true') {
            notice.remove();
            return;
        }

        function setCollapsed(collapsed) {
            notice.classList.toggle('is-collapsed', collapsed);
            toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            if (collapsed) {
                localStorage.setItem(collapsedKey, 'true');
            } else {
                localStorage.removeItem(collapsedKey);
            }
        }

        setCollapsed(localStorage.getItem(collapsedKey) === 'true');

        toggle.addEventListener('click', function () {
            setCollapsed(!notice.classList.contains('is-collapsed'));
        });

        dismiss.addEventListener('click', function () {
            localStorage.setItem(dismissedKey, 'true');
            notice.remove();
        });
    });
})();
</script>

<script>
(function () {
    var root = document.getElementById('makepay-settlement-route');
    var currencyHidden = document.getElementById('SettlementCurrency');
    var prioritiesHidden = document.getElementById('SettlementPrioritiesJson');
    var chainHidden = document.getElementById('ChainAddressesJson');
    var currencySelect = document.getElementById('makepay-settlement-currency');
    var chainSelect = document.getElementById('makepay-settlement-chain');
    var help = document.getElementById('makepay-settlement-route-help');
    var panel = document.getElementById('makepay-custom-settlement-panel');
    if (!root || !currencyHidden || !prioritiesHidden || !chainHidden || !currencySelect || !chainSelect || !help || !panel) {
        return;
    }

    var modeInputs = Array.from(document.querySelectorAll('input[name="SettlementMode"]'));
    var addresses = parseAddressBook(chainHidden.value);
    var routesByCurrency = new Map();

    function readText(value) {
        return String(value || '').trim();
    }

    function normalizeSymbol(value) {
        var normalized = readText(value).split('.', 1)[0].toUpperCase();
        var aliases = {
            BINANCE: 'BNB',
            POLYGON: 'POL',
            TRX: 'TRON'
        };
        normalized = aliases[normalized] || normalized;
        return /^[A-Z0-9_]{2,24}$/.test(normalized) ? normalized : '';
    }

    function parseAddressBook(value) {
        var output = new Map();
        try {
            var parsed = JSON.parse(String(value || '[]'));
            if (Array.isArray(parsed)) {
                parsed.forEach(function (item) {
                    var chain = normalizeSymbol(item && (item.chain || item.Chain || item.chainCode || item.ChainCode));
                    var address = readText(item && (item.address || item.Address || item.sourceAddress || item.SourceAddress));
                    if (chain && address) {
                        output.set(chain, address);
                    }
                });
            } else if (parsed && typeof parsed === 'object') {
                Object.keys(parsed).forEach(function (key) {
                    var value = parsed[key];
                    var chain = normalizeSymbol(key);
                    var address = typeof value === 'string'
                        ? readText(value)
                        : readText(value && (value.address || value.Address || value.sourceAddress || value.SourceAddress));
                    if (chain && address) {
                        output.set(chain, address);
                    }
                });
            }
        } catch (error) {
            return output;
        }

        return output;
    }

    function tokenIdentifier(token) {
        return readText(token && (token.identifier || token.assetIdentifier || token.id));
    }

    function tokenChain(token) {
        return normalizeSymbol(tokenIdentifier(token)) ||
            normalizeSymbol(token && (token.chain || token.chainCode || token.network || token.chainId));
    }

    function tokenCurrency(token) {
        var identifier = tokenIdentifier(token);
        var fromIdentifier = identifier.indexOf('.') > -1
            ? identifier.split('.').slice(1).join('.')
            : '';
        return normalizeSymbol(token && (token.ticker || token.symbol || token.currency || fromIdentifier));
    }

    function tokenLabel(token, currency, chain) {
        var name = readText(token && token.name);
        return name && name.toUpperCase() !== currency ? currency + ' - ' + name : currency + ' on ' + chain;
    }

    function selectedMode() {
        var selected = modeInputs.find(function (input) { return input.checked; });
        return selected ? selected.value : '@MakePayPaymentMethodConfig.SettlementModeBtcpay';
    }

    function setMode(mode) {
        modeInputs.forEach(function (input) {
            input.checked = input.value === mode;
        });
        updatePanel();
        writeHidden();
    }

    function routeKey(route) {
        return route.currency + ':' + route.chain + ':' + route.asset;
    }

    function buildRoutes(tokens) {
        routesByCurrency.clear();
        tokens.forEach(function (token) {
            var chain = tokenChain(token);
            var currency = tokenCurrency(token);
            var address = addresses.get(chain);
            if (!chain || !currency || !address) {
                return;
            }

            var asset = tokenIdentifier(token) || (chain + '.' + currency);
            var route = {
                currency: currency,
                chain: chain,
                address: address,
                asset: asset,
                label: tokenLabel(token, currency, chain)
            };
            var routes = routesByCurrency.get(currency) || [];
            if (!routes.some(function (existing) { return routeKey(existing) === routeKey(route); })) {
                routes.push(route);
            }
            routesByCurrency.set(currency, routes);
        });

        routesByCurrency.forEach(function (routes) {
            routes.sort(function (a, b) {
                if (a.chain === 'BTC') {
                    return -1;
                }
                if (b.chain === 'BTC') {
                    return 1;
                }
                return a.chain.localeCompare(b.chain);
            });
        });
    }

    function parseCurrentPriority() {
        try {
            var parsed = JSON.parse(String(prioritiesHidden.value || '[]'));
            if (!Array.isArray(parsed) || parsed.length === 0) {
                return null;
            }

            var first = parsed[0];
            return {
                chain: normalizeSymbol(first && (first.chain || first.Chain || first.chainCode || first.ChainCode)),
                asset: readText(first && (first.asset || first.Asset || first.assetIdentifier || first.AssetIdentifier))
            };
        } catch (error) {
            return null;
        }
    }

    function renderCurrencyOptions() {
        currencySelect.innerHTML = '';
        Array.from(routesByCurrency.keys()).sort().forEach(function (currency) {
            var option = document.createElement('option');
            option.value = currency;
            option.textContent = currency;
            currencySelect.appendChild(option);
        });
    }

    function findBestRoute(currency, preferred) {
        var routes = routesByCurrency.get(currency) || [];
        if (preferred) {
            var exact = routes.find(function (route) {
                return route.chain === preferred.chain &&
                    (!preferred.asset || route.asset === preferred.asset);
            });
            if (exact) {
                return exact;
            }
        }
        return routes[0] || null;
    }

    function renderChainOptions(preferred) {
        chainSelect.innerHTML = '';
        var routes = routesByCurrency.get(currencySelect.value) || [];
        routes.forEach(function (route) {
            var option = document.createElement('option');
            option.value = routeKey(route);
            option.textContent = route.chain + ' - ' + route.label;
            option.dataset.currency = route.currency;
            option.dataset.chain = route.chain;
            option.dataset.asset = route.asset;
            option.dataset.address = route.address;
            chainSelect.appendChild(option);
        });

        var selected = findBestRoute(currencySelect.value, preferred);
        if (selected) {
            chainSelect.value = routeKey(selected);
        }
    }

    function selectedRoute() {
        var option = chainSelect.selectedOptions[0];
        if (!option) {
            return null;
        }

        return {
            currency: option.dataset.currency,
            chain: option.dataset.chain,
            asset: option.dataset.asset,
            address: option.dataset.address
        };
    }

    function truncateAddress(address) {
        address = readText(address);
        return address.length > 22 ? address.slice(0, 12) + '...' + address.slice(-8) : address;
    }

    function updatePanel() {
        var custom = selectedMode() === '@MakePayPaymentMethodConfig.SettlementModeCustom';
        panel.classList.toggle('d-none', !custom);
        currencySelect.disabled = !custom || routesByCurrency.size === 0;
        chainSelect.disabled = !custom || chainSelect.options.length === 0;
    }

    function writeHidden() {
        if (selectedMode() !== '@MakePayPaymentMethodConfig.SettlementModeCustom') {
            currencyHidden.value = 'BTC';
            prioritiesHidden.value = '';
            help.textContent = routesByCurrency.size === 0
                ? 'Add settlement addresses before selecting a custom MakePay route.'
                : 'BTCPay Server settlement is selected. A fresh BTC address will be reserved for each invoice.';
            return;
        }

        var route = selectedRoute();
        if (!route) {
            prioritiesHidden.value = '';
            help.textContent = 'No saved settlement route is available for the selected currency.';
            return;
        }

        currencyHidden.value = route.currency;
        prioritiesHidden.value = JSON.stringify([{
            chain: route.chain,
            address: route.address,
            asset: route.asset
        }]);
        help.textContent = 'MakePay will settle ' + route.currency + ' on ' + route.chain + ' to ' + truncateAddress(route.address) + '.';
    }

    function initializeRoutes(tokens) {
        buildRoutes(tokens);
        renderCurrencyOptions();

        if (routesByCurrency.size === 0) {
            setMode('@MakePayPaymentMethodConfig.SettlementModeBtcpay');
            modeInputs.forEach(function (input) {
                if (input.value === '@MakePayPaymentMethodConfig.SettlementModeCustom') {
                    input.disabled = true;
                }
            });
            return;
        }

        var priority = parseCurrentPriority();
        var initialCurrency = routesByCurrency.has(currencyHidden.value)
            ? currencyHidden.value
            : Array.from(routesByCurrency.keys()).sort()[0];
        if (priority) {
            routesByCurrency.forEach(function (routes, currency) {
                if (routes.some(function (route) { return route.chain === priority.chain && (!priority.asset || route.asset === priority.asset); })) {
                    initialCurrency = currency;
                }
            });
        }

        currencySelect.value = initialCurrency;
        renderChainOptions(priority);
        updatePanel();
        writeHidden();
    }

    modeInputs.forEach(function (input) {
        input.addEventListener('change', function () {
            updatePanel();
            writeHidden();
        });
    });

    currencySelect.addEventListener('change', function () {
        renderChainOptions(null);
        writeHidden();
    });

    chainSelect.addEventListener('change', writeHidden);

    fetch(root.dataset.url, { cache: 'no-store' })
        .then(function (response) {
            return response.json().then(function (payload) {
                if (!response.ok || !Array.isArray(payload)) {
                    throw new Error(payload && payload.error ? payload.error : 'Unable to load MakePay settlement routes.');
                }
                return payload;
            });
        })
        .then(initializeRoutes)
        .catch(function (error) {
            setMode('@MakePayPaymentMethodConfig.SettlementModeBtcpay');
            modeInputs.forEach(function (input) {
                if (input.value === '@MakePayPaymentMethodConfig.SettlementModeCustom') {
                    input.disabled = true;
                }
            });
            help.textContent = error && error.message ? error.message : 'Unable to load MakePay settlement routes.';
        });
})();
</script>

<script>
(function () {
    var list = document.getElementById('makepay-currencies-list');
    var hidden = document.getElementById('AllowedAssetIdentifiers');
    var allowAll = document.getElementById('makepay-allow-all-currencies');
    if (!list || !hidden || !allowAll) {
        return;
    }

    var tokens = [];
    var selected = new Set(parseHiddenValue(hidden.value));

    function parseHiddenValue(value) {
        return String(value || '')
            .split(/[,\n\r]+/)
            .map(function (item) { return item.trim(); })
            .filter(function (item) { return item.length > 0; });
    }

    function tokenIdentifier(token) {
        return String(token.identifier || '').trim();
    }

    function tokenTicker(token) {
        return String(token.ticker || token.symbol || '').trim();
    }

    function tokenNetwork(token) {
        return String(token.network || token.chain || token.chainId || '').trim();
    }

    function tokenName(token) {
        return String(token.name || tokenTicker(token) || tokenIdentifier(token)).trim();
    }

    function tokenLabel(token) {
        var ticker = tokenTicker(token);
        var network = tokenNetwork(token);
        return network ? ticker + ' - ' + network : ticker;
    }

    function writeHidden() {
        hidden.value = allowAll.checked ? '' : Array.from(selected).sort().join('\n');
    }

    function render() {
        list.innerHTML = '';

        if (tokens.length === 0) {
            var empty = document.createElement('div');
            empty.className = 'list-group-item text-muted';
            empty.textContent = 'No MakePay currencies are available.';
            list.appendChild(empty);
            return;
        }

        tokens.forEach(function (token) {
            var identifier = tokenIdentifier(token);
            if (!identifier) {
                return;
            }

            var row = document.createElement('label');
            row.className = 'list-group-item d-flex align-items-center justify-content-between gap-3';

            var text = document.createElement('span');
            text.className = 'd-flex flex-column text-break';

            var title = document.createElement('span');
            title.className = 'fw-semibold';
            title.textContent = tokenLabel(token) || identifier;

            var detail = document.createElement('small');
            detail.className = 'text-muted';
            var name = tokenName(token);
            detail.textContent = name && name !== title.textContent
                ? name + ' - ' + identifier
                : identifier;

            text.appendChild(title);
            text.appendChild(detail);

            var toggle = document.createElement('input');
            toggle.type = 'checkbox';
            toggle.className = 'btcpay-toggle flex-shrink-0';
            toggle.checked = allowAll.checked || selected.has(identifier);
            toggle.disabled = allowAll.checked;
            toggle.addEventListener('change', function () {
                if (toggle.checked) {
                    selected.add(identifier);
                } else {
                    selected.delete(identifier);
                }
                writeHidden();
            });

            row.appendChild(text);
            row.appendChild(toggle);
            list.appendChild(row);
        });
    }

    allowAll.checked = selected.size === 0;
    allowAll.addEventListener('change', function () {
        if (!allowAll.checked && selected.size === 0) {
            tokens.forEach(function (token) {
                var identifier = tokenIdentifier(token);
                if (identifier) {
                    selected.add(identifier);
                }
            });
        }
        writeHidden();
        render();
    });

    fetch(list.dataset.url, { cache: 'no-store' })
        .then(function (response) {
            return response.json().then(function (payload) {
                if (!response.ok || !Array.isArray(payload)) {
                    throw new Error(payload && payload.error ? payload.error : 'Unable to load MakePay currencies.');
                }
                return payload;
            });
        })
        .then(function (payload) {
            tokens = payload
                .filter(function (token) { return token && tokenIdentifier(token); })
                .sort(function (a, b) {
                    return (tokenLabel(a) || tokenIdentifier(a))
                        .localeCompare(tokenLabel(b) || tokenIdentifier(b));
                });
            render();
            writeHidden();
        })
        .catch(function (error) {
            list.innerHTML = '';
            var message = document.createElement('div');
            message.className = 'list-group-item text-danger';
            message.textContent = error && error.message ? error.message : 'Unable to load MakePay currencies.';
            list.appendChild(message);
        });
})();
</script>

<script>
(function () {
    var list = document.getElementById('makepay-chain-address-list');
    var search = document.getElementById('makepay-chain-address-search');
    var chainHidden = document.getElementById('ChainAddressesJson');
    var prioritiesHidden = document.getElementById('SettlementPrioritiesJson');
    var currencyHidden = document.getElementById('SettlementCurrency');
    var summary = document.getElementById('makepay-chain-address-summary');
    if (!list || !search || !chainHidden || !prioritiesHidden || !currencyHidden || !summary) {
        return;
    }

    var chainRecords = new Map();
    var cardNodes = new Map();
    var addresses = parseAddressBook(chainHidden.value);
    var evmChains = ['ETH', 'ARB', 'AVAX', 'BASE', 'OP', 'POL', 'BERA', 'GNO', 'MONAD', 'XLAYER', 'BNB', 'BSC'];
    var evmSet = new Set(evmChains);
    var preferredOrder = ['BTC', 'ETH', 'TRON', 'SOL', 'ARB', 'BASE', 'OP', 'POL', 'BSC', 'BNB'];
    var chainLabels = {
        ADA: 'Cardano',
        ARB: 'Arbitrum',
        AVAX: 'Avalanche',
        BASE: 'Base',
        BCH: 'Bitcoin Cash',
        BERA: 'Berachain',
        BNB: 'BNB Chain',
        BSC: 'BNB Smart Chain',
        BTC: 'Bitcoin',
        DASH: 'Dash',
        DOGE: 'Dogecoin',
        DOT: 'Polkadot',
        ETH: 'Ethereum',
        GNO: 'Gnosis',
        LTC: 'Litecoin',
        MATIC: 'Polygon',
        MAYA: 'MayaChain',
        MONAD: 'Monad',
        NEAR: 'NEAR',
        OP: 'Optimism',
        POL: 'Polygon',
        SOL: 'Solana',
        STRK: 'Starknet',
        SUI: 'Sui',
        THOR: 'THORChain',
        TON: 'TON',
        TRON: 'TRON',
        XLAYER: 'X Layer',
        XRP: 'XRP Ledger',
        ZEC: 'Zcash'
    };

    function readText(value) {
        return String(value || '').trim();
    }

    function normalizeChain(value) {
        var normalized = readText(value).split('.', 1)[0].toUpperCase();
        var aliases = {
            BINANCE: 'BNB',
            POLYGON: 'POL',
            TRX: 'TRON'
        };
        normalized = aliases[normalized] || normalized;
        return /^[A-Z0-9_]{2,24}$/.test(normalized) ? normalized : '';
    }

    function parseAddressBook(value) {
        var output = new Map();
        try {
            var parsed = JSON.parse(String(value || '[]'));
            if (Array.isArray(parsed)) {
                parsed.forEach(function (item) {
                    var chain = normalizeChain(item && (item.chain || item.Chain || item.chainCode || item.ChainCode));
                    var address = readText(item && (item.address || item.Address || item.sourceAddress || item.SourceAddress));
                    if (chain && address) {
                        output.set(chain, address);
                    }
                });
            } else if (parsed && typeof parsed === 'object') {
                Object.keys(parsed).forEach(function (key) {
                    var value = parsed[key];
                    var chain = normalizeChain(key);
                    var address = typeof value === 'string'
                        ? readText(value)
                        : readText(value && (value.address || value.Address || value.sourceAddress || value.SourceAddress));
                    if (chain && address) {
                        output.set(chain, address);
                    }
                });
            }
        } catch (error) {
            return output;
        }

        return output;
    }

    function tokenIdentifier(token) {
        return readText(token && (token.identifier || token.assetIdentifier || token.id));
    }

    function tokenChain(token) {
        return normalizeChain(tokenIdentifier(token)) ||
            normalizeChain(token && (token.chain || token.chainCode || token.network || token.chainId));
    }

    function tokenTicker(token) {
        var identifier = tokenIdentifier(token);
        var fromIdentifier = identifier.indexOf('.') > -1
            ? identifier.split('.').slice(1).join('.')
            : '';
        return readText(token && (token.ticker || token.symbol || token.currency || fromIdentifier));
    }

    function tokenLogo(token) {
        return readText(token && (token.logoURI || token.logoUri || token.logoUrl || token.icon || token.image || token.imageUrl));
    }

    function chainLabel(chain) {
        return chainLabels[chain] || chain;
    }

    function truncateAddress(address) {
        address = readText(address);
        if (address.length <= 18) {
            return address || 'Not set';
        }

        return address.slice(0, 10) + '...' + address.slice(-6);
    }

    function buildChainRecords(tokens) {
        chainRecords.clear();

        tokens.forEach(function (token) {
            var chain = tokenChain(token);
            if (!chain) {
                return;
            }

            var record = chainRecords.get(chain);
            if (!record) {
                record = {
                    chain: chain,
                    label: chainLabel(chain),
                    logo: '',
                    assets: [],
                    assetKeys: new Set()
                };
                chainRecords.set(chain, record);
            }

            var logo = tokenLogo(token);
            if (!record.logo && logo) {
                record.logo = logo;
            }

            var identifier = tokenIdentifier(token);
            var symbol = tokenTicker(token);
            var key = identifier || symbol;
            if (key && !record.assetKeys.has(key)) {
                record.assetKeys.add(key);
                record.assets.push({
                    identifier: identifier,
                    symbol: symbol || identifier
                });
            }
        });
    }

    function orderedRecords() {
        var query = readText(search.value).toUpperCase();
        return Array.from(chainRecords.values())
            .filter(function (record) {
                if (!query) {
                    return true;
                }

                return record.chain.indexOf(query) > -1 ||
                    record.label.toUpperCase().indexOf(query) > -1 ||
                    record.assets.some(function (asset) {
                        return readText(asset.symbol).toUpperCase().indexOf(query) > -1 ||
                            readText(asset.identifier).toUpperCase().indexOf(query) > -1;
                    });
            })
            .sort(function (a, b) {
                if (a.chain === 'BTC') {
                    return -1;
                }
                if (b.chain === 'BTC') {
                    return 1;
                }

                var aMissing = !addresses.has(a.chain);
                var bMissing = !addresses.has(b.chain);
                if (aMissing !== bMissing) {
                    return aMissing ? -1 : 1;
                }

                var aPreferred = preferredOrder.indexOf(a.chain);
                var bPreferred = preferredOrder.indexOf(b.chain);
                if (aPreferred !== -1 || bPreferred !== -1) {
                    if (aPreferred === -1) {
                        return 1;
                    }
                    if (bPreferred === -1) {
                        return -1;
                    }
                    return aPreferred - bPreferred;
                }

                return a.chain.localeCompare(b.chain);
            });
    }

    function addressIsValid(chain, address) {
        if (!address || !evmSet.has(chain)) {
            return true;
        }

        return /^0x[a-fA-F0-9]{40}$/.test(address);
    }

    function writeHidden() {
        var entries = Array.from(addresses.entries())
            .map(function (entry) {
                return {
                    chain: entry[0],
                    address: readText(entry[1])
                };
            })
            .filter(function (entry) {
                return entry.chain && entry.address;
            })
            .sort(function (a, b) {
                return a.chain.localeCompare(b.chain);
            });

        chainHidden.value = entries.length ? JSON.stringify(entries) : '';
        currencyHidden.value = 'BTC';

        var btcAddress = readText(addresses.get('BTC'));
        prioritiesHidden.value = btcAddress
            ? JSON.stringify([{ chain: 'BTC', address: btcAddress, asset: 'BTC.BTC' }])
            : '';
    }

    function updateSummary() {
        var total = chainRecords.size;
        var setCount = Array.from(chainRecords.keys()).filter(function (chain) {
            return addresses.has(chain);
        }).length;
        var missing = Math.max(total - setCount, 0);

        summary.querySelector('[data-role="total"]').textContent = total + (total === 1 ? ' chain' : ' chains');
        summary.querySelector('[data-role="missing"]').textContent = missing + ' missing';
        summary.querySelector('[data-role="set"]').textContent = setCount + ' set';
    }

    function compatibleTargets(chain) {
        if (!evmSet.has(chain)) {
            return [];
        }

        return evmChains.filter(function (candidate) {
            return candidate !== chain;
        });
    }

    function supportedCompatibleTargets(chain) {
        return compatibleTargets(chain).filter(function (candidate) {
            return chainRecords.has(candidate);
        });
    }

    function updateCard(chain) {
        var card = cardNodes.get(chain);
        if (!card) {
            return;
        }

        var address = readText(addresses.get(chain));
        var hasAddress = address.length > 0;
        var valid = addressIsValid(chain, address);
        var status = card.querySelector('[data-role="status"]');
        var detail = card.querySelector('[data-role="detail"]');
        var input = card.querySelector('[data-role="address-input"]');

        if (input && input.value !== address) {
            input.value = address;
        }

        card.classList.toggle('border-warning', !hasAddress && chain === 'BTC');
        card.classList.toggle('border-danger', hasAddress && !valid);

        if (status) {
            if (hasAddress && valid) {
                status.className = 'badge makepay-badge-set border';
                status.textContent = 'Address set';
            } else if (hasAddress && !valid) {
                status.className = 'badge makepay-badge-danger border';
                status.textContent = 'Invalid address';
            } else if (chain === 'BTC') {
                status.className = 'badge makepay-badge-missing border';
                status.textContent = 'Required';
            } else {
                status.className = 'badge makepay-badge-missing border';
                status.textContent = 'Missing address';
            }
        }

        if (detail) {
            if (hasAddress && valid) {
                detail.textContent = 'Saved address ' + truncateAddress(address) + '.';
            } else if (hasAddress && !valid) {
                detail.textContent = 'Use a valid 0x address for ' + chainLabel(chain) + '.';
            } else if (chain === 'BTC') {
                detail.textContent = 'Add the BTC address used for anonymous settlement.';
            } else {
                detail.textContent = 'Add the merchant refund address for ' + chainLabel(chain) + '.';
            }
        }

        writeHidden();
        updateSummary();
    }

    function setAddress(chain, address) {
        address = readText(address);
        if (address) {
            addresses.set(chain, address);
        } else {
            addresses.delete(chain);
        }
        updateCard(chain);
    }

    function applyCompatibleAddress(chain, address) {
        address = readText(address);
        if (!address) {
            return;
        }

        supportedCompatibleTargets(chain).forEach(function (target) {
            addresses.set(target, address);
            updateCard(target);
        });
    }

    function createLogo(record) {
        if (record.logo) {
            var img = document.createElement('img');
            img.className = 'makepay-chain-logo rounded-circle border flex-shrink-0';
            img.src = record.logo;
            img.alt = record.chain;
            img.loading = 'lazy';
            img.addEventListener('error', function () {
                var fallback = createLogoFallback(record);
                img.replaceWith(fallback);
            });
            return img;
        }

        return createLogoFallback(record);
    }

    function createLogoFallback(record) {
        var fallback = document.createElement('span');
        fallback.className = 'makepay-chain-logo-fallback rounded-circle border d-inline-flex align-items-center justify-content-center bg-secondary-subtle text-secondary-emphasis fw-semibold flex-shrink-0';
        fallback.textContent = record.chain.slice(0, 3);
        return fallback;
    }

    function renderAssets(record, container) {
        record.assets.slice(0, 5).forEach(function (asset) {
            var chip = document.createElement('span');
            chip.className = 'badge rounded-pill bg-light text-dark border';
            chip.textContent = asset.symbol || asset.identifier;
            chip.title = asset.identifier || asset.symbol || '';
            container.appendChild(chip);
        });

        if (record.assets.length > 5) {
            var more = document.createElement('span');
            more.className = 'badge rounded-pill bg-light text-muted border';
            more.textContent = '+' + (record.assets.length - 5) + ' more';
            container.appendChild(more);
        }
    }

    function createCard(record) {
        var card = document.createElement('div');
        card.className = 'makepay-chain-address-card border rounded p-3';
        card.dataset.chain = record.chain;

        var top = document.createElement('div');
        top.className = 'd-flex align-items-start gap-3';
        top.appendChild(createLogo(record));

        var body = document.createElement('div');
        body.className = 'min-w-0 flex-grow-1';

        var titleRow = document.createElement('div');
        titleRow.className = 'd-flex flex-wrap align-items-center gap-2 mb-1';

        var title = document.createElement('div');
        title.className = 'fw-semibold';
        title.textContent = record.chain;
        titleRow.appendChild(title);

        var label = document.createElement('span');
        label.className = 'badge rounded-pill bg-light text-dark border';
        label.textContent = record.label;
        titleRow.appendChild(label);

        if (record.chain === 'BTC') {
            var settlement = document.createElement('span');
            settlement.className = 'badge rounded-pill bg-secondary-subtle text-secondary-emphasis border';
            settlement.textContent = 'Settlement chain';
            titleRow.appendChild(settlement);
        }

        var status = document.createElement('span');
        status.dataset.role = 'status';
        titleRow.appendChild(status);

        var detail = document.createElement('div');
        detail.className = 'text-muted small mb-3 text-break';
        detail.dataset.role = 'detail';

        var inputGroup = document.createElement('div');
        inputGroup.className = 'input-group input-group-sm';

        var input = document.createElement('input');
        input.type = 'text';
        input.className = 'form-control';
        input.placeholder = 'Merchant ' + record.chain + ' address';
        input.autocomplete = 'off';
        input.dataset.role = 'address-input';
        input.dataset.chain = record.chain;
        input.value = readText(addresses.get(record.chain));

        var clear = document.createElement('button');
        clear.type = 'button';
        clear.className = 'btn btn-outline-secondary';
        clear.dataset.role = 'clear-address';
        clear.dataset.chain = record.chain;
        clear.textContent = 'Clear';

        inputGroup.appendChild(input);
        inputGroup.appendChild(clear);

        var assets = document.createElement('div');
        assets.className = 'd-flex flex-wrap gap-1 mt-3';
        renderAssets(record, assets);

        body.appendChild(titleRow);
        body.appendChild(detail);
        body.appendChild(inputGroup);
        body.appendChild(assets);

        var targets = compatibleTargets(record.chain);
        if (targets.length > 0) {
            var compatible = document.createElement('div');
            compatible.className = 'border rounded mt-3 p-3 bg-light bg-opacity-50';

            var compatibleLabel = document.createElement('label');
            compatibleLabel.className = 'd-flex align-items-start gap-2 mb-0';

            var checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.className = 'form-check-input mt-1';
            checkbox.dataset.role = 'compatible-toggle';
            checkbox.dataset.chain = record.chain;

            var text = document.createElement('span');
            text.className = 'small';

            var strong = document.createElement('span');
            strong.className = 'd-block fw-semibold';
            strong.textContent = 'Also save this address for compatible 0x chains';

            var copy = document.createElement('span');
            copy.className = 'd-block text-muted mt-1';
            copy.textContent = record.chain + ' shares the same public address format with ' + targets.join(', ') + '. If you confirm, we will save the same refund address there too.';

            text.appendChild(strong);
            text.appendChild(copy);
            compatibleLabel.appendChild(checkbox);
            compatibleLabel.appendChild(text);
            compatible.appendChild(compatibleLabel);
            body.appendChild(compatible);
        }

        top.appendChild(body);
        card.appendChild(top);
        cardNodes.set(record.chain, card);
        updateCard(record.chain);
        return card;
    }

    function render() {
        cardNodes.clear();
        list.innerHTML = '';

        var records = orderedRecords();
        if (records.length === 0) {
            var empty = document.createElement('div');
            empty.className = 'border rounded p-3 text-muted';
            empty.textContent = 'No chains match your search.';
            list.appendChild(empty);
            updateSummary();
            writeHidden();
            return;
        }

        records.forEach(function (record) {
            list.appendChild(createCard(record));
        });

        updateSummary();
        writeHidden();
    }

    search.addEventListener('input', render);

    list.addEventListener('input', function (event) {
        var target = event.target;
        if (!target || target.dataset.role !== 'address-input') {
            return;
        }

        var chain = target.dataset.chain;
        setAddress(chain, target.value);

        var card = cardNodes.get(chain);
        var toggle = card && card.querySelector('[data-role="compatible-toggle"]');
        if (toggle && toggle.checked) {
            applyCompatibleAddress(chain, target.value);
        }
    });

    list.addEventListener('change', function (event) {
        var target = event.target;
        if (!target || target.dataset.role !== 'compatible-toggle' || !target.checked) {
            return;
        }

        applyCompatibleAddress(target.dataset.chain, addresses.get(target.dataset.chain));
    });

    list.addEventListener('click', function (event) {
        var target = event.target;
        if (!target || target.dataset.role !== 'clear-address') {
            return;
        }

        var chain = target.dataset.chain;
        setAddress(chain, '');

        var card = cardNodes.get(chain);
        var toggle = card && card.querySelector('[data-role="compatible-toggle"]');
        if (toggle) {
            toggle.checked = false;
        }
    });

    fetch(list.dataset.url, { cache: 'no-store' })
        .then(function (response) {
            return response.json().then(function (payload) {
                if (!response.ok || !Array.isArray(payload)) {
                    throw new Error(payload && payload.error ? payload.error : 'Unable to load MakePay chains.');
                }
                return payload;
            });
        })
        .then(function (payload) {
            buildChainRecords(payload);
            render();
        })
        .catch(function (error) {
            list.innerHTML = '';
            var message = document.createElement('div');
            message.className = 'border rounded p-3 text-danger';
            message.textContent = error && error.message ? error.message : 'Unable to load MakePay chains.';
            list.appendChild(message);
            writeHidden();
        });
})();
</script>
