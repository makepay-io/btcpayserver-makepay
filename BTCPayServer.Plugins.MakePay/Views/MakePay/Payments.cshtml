@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.MakePay.Models
@model MakePayPaymentsViewModel
@{
    ViewData.SetActivePage("MakePayPayments", "MakePay", "MakePay Payments");
}

<div id="makepay-payments"
     data-store-id="@Model.StoreId"
     data-url="@Model.DataUrl"
     data-invoice-url="@Model.InvoiceUrlTemplate"
     data-payment-url="@Model.PaymentDetailsUrlTemplate">
    <div class="sticky-header-setup"></div>
    <div class="sticky-header d-flex align-items-center justify-content-between gap-3">
        <div>
            <h2 class="mb-0">Payments</h2>
            <div class="text-secondary small mt-1" data-makepay-sync-status aria-live="polite">
                Loading saved payments…
            </div>
        </div>
        <button type="button" class="btn btn-secondary d-flex align-items-center gap-2" data-makepay-refresh>
            <vc:icon symbol="actions-refresh" />
            <span>Refresh</span>
        </button>
    </div>

    <partial name="_StatusMessage" />

    <form class="makepay-filter-bar d-flex flex-wrap align-items-end gap-3 mb-4" data-makepay-filters>
        <div class="flex-grow-1 makepay-filter-search">
            <label class="form-label" for="makepay-search">Search</label>
            <input id="makepay-search" name="searchTerm" class="form-control" type="search"
                   placeholder="Invoice, session, address, tx" />
        </div>
        <div>
            <label class="form-label" for="makepay-status-filter">Status</label>
            <select id="makepay-status-filter" name="status" class="form-select">
                <option value="">All Status</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="makepay-asset-filter">Asset</label>
            <select id="makepay-asset-filter" name="asset" class="form-select">
                <option value="">All Assets</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="makepay-network-filter">Network</label>
            <select id="makepay-network-filter" name="network" class="form-select">
                <option value="">All Networks</option>
            </select>
        </div>
        <div>
            <label class="form-label" for="makepay-time-filter">Time</label>
            <select id="makepay-time-filter" name="timeRange" class="form-select" data-makepay-time-filter>
                <option value="">All Time</option>
                <option value="24h">Last 24 hours</option>
                <option value="3d">Last 3 days</option>
                <option value="7d">Last 7 days</option>
                <option value="30d">Last 30 days</option>
                <option value="custom">Custom range</option>
            </select>
        </div>
        <div class="makepay-custom-range" data-makepay-custom-range hidden>
            <label class="form-label" for="makepay-start-date">Start</label>
            <input id="makepay-start-date" name="startDate" class="form-control" type="datetime-local" />
        </div>
        <div class="makepay-custom-range" data-makepay-custom-range hidden>
            <label class="form-label" for="makepay-end-date">End</label>
            <input id="makepay-end-date" name="endDate" class="form-control" type="datetime-local" />
        </div>
        <button type="submit" class="btn btn-primary">Search</button>
        <button type="button" class="btn btn-secondary" data-makepay-clear hidden>Clear</button>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th class="text-nowrap">Date</th>
                <th>Invoice</th>
                <th>Method</th>
                <th>Asset</th>
                <th>Deposit</th>
                <th>Transaction</th>
                <th>Status</th>
                <th class="text-end">Amount</th>
            </tr>
            </thead>
            <tbody data-makepay-payment-rows>
            <tr>
                <td colspan="8" class="py-5 text-center">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status">
                        <span class="visually-hidden">Loading payments…</span>
                    </div>
                </td>
            </tr>
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4" data-makepay-pagination hidden>
        <button type="button" class="btn btn-secondary" data-makepay-previous>Previous</button>
        <div class="text-secondary small" data-makepay-page-summary></div>
        <button type="button" class="btn btn-secondary" data-makepay-next>Next</button>
    </div>
</div>

<style>
    .makepay-filter-search {
        min-width: min(100%, 20rem);
    }

    .makepay-filter-bar select,
    .makepay-filter-bar input[type="datetime-local"] {
        min-width: 10rem;
    }

    .makepay-custom-range[hidden],
    [data-makepay-pagination][hidden] {
        display: none !important;
    }

    [data-makepay-refresh][aria-busy="true"] .icon {
        animation: makepay-spin .8s linear infinite;
    }

    .makepay-payment-meta {
        max-width: 14rem;
    }

    @@keyframes makepay-spin {
        to { transform: rotate(360deg); }
    }
</style>

<script>
(function () {
    const root = document.getElementById('makepay-payments');
    if (!root) return;

    const dataUrl = root.dataset.url;
    const storeId = root.dataset.storeId;
    const invoiceUrlTemplate = root.dataset.invoiceUrl;
    const paymentUrlTemplate = root.dataset.paymentUrl;
    const rows = root.querySelector('[data-makepay-payment-rows]');
    const form = root.querySelector('[data-makepay-filters]');
    const refreshButton = root.querySelector('[data-makepay-refresh]');
    const clearButton = root.querySelector('[data-makepay-clear]');
    const syncStatus = root.querySelector('[data-makepay-sync-status]');
    const pagination = root.querySelector('[data-makepay-pagination]');
    const previousButton = root.querySelector('[data-makepay-previous]');
    const nextButton = root.querySelector('[data-makepay-next]');
    const pageSummary = root.querySelector('[data-makepay-page-summary]');
    const timeFilter = root.querySelector('[data-makepay-time-filter]');
    const customRangeFields = root.querySelectorAll('[data-makepay-custom-range]');
    const cacheVersion = 'v2';
    let pollTimer = null;
    let requestNumber = 0;
    let hasRenderedData = false;

    function element(tag, className, text) {
        const node = document.createElement(tag);
        if (className) node.className = className;
        if (text !== undefined && text !== null) node.textContent = text;
        return node;
    }

    function queryParams() {
        const params = new URLSearchParams(window.location.search);
        ['searchTerm', 'status', 'asset', 'network', 'timeRange', 'startDate', 'endDate', 'skip']
            .forEach(key => {
                if (!params.get(key)) params.delete(key);
            });
        return params;
    }

    function cacheKey(params) {
        const normalized = new URLSearchParams(params);
        normalized.delete('refresh');
        return `makepay:payments:${cacheVersion}:${storeId}:${normalized.toString()}`;
    }

    function readCache(params) {
        try {
            const cached = JSON.parse(localStorage.getItem(cacheKey(params)));
            if (!cached || !cached.savedAt || Date.now() - cached.savedAt > 24 * 60 * 60 * 1000) return null;
            return cached.data;
        } catch (_) {
            return null;
        }
    }

    function writeCache(params, data) {
        try {
            localStorage.setItem(cacheKey(params), JSON.stringify({ savedAt: Date.now(), data }));
        } catch (_) {
            // Private browsing and strict storage policies should not block the page.
        }
    }

    function fillForm(params) {
        Array.from(form.elements).forEach(control => {
            if (!control.name) return;
            control.value = params.get(control.name) || '';
        });
        updateCustomRange();
        clearButton.hidden = !hasFilters(params);
    }

    function hasFilters(params) {
        return ['searchTerm', 'status', 'asset', 'network', 'timeRange', 'startDate', 'endDate']
            .some(key => Boolean(params.get(key)));
    }

    function updateCustomRange() {
        const show = timeFilter.value === 'custom';
        customRangeFields.forEach(field => field.hidden = !show);
    }

    function populateSelect(name, values, defaultText, selected) {
        const select = form.elements[name];
        select.replaceChildren(new Option(defaultText, ''));
        (values || []).forEach(value => select.add(new Option(value, value, false, value === selected)));
        select.value = selected || '';
    }

    function short(value, start = 7, end = 7) {
        if (!value || value.length <= start + end + 1) return value || '';
        return `${value.slice(0, start)}…${value.slice(-end)}`;
    }

    function displayAsset(value) {
        if (!value || value.toLowerCase() === 'null') return '-';
        const parts = value.split('.', 2);
        if (parts.length < 2) return value;
        const ticker = parts[1].split('-', 1)[0].toUpperCase();
        return `${ticker} on ${parts[0].toUpperCase()}`;
    }

    function displayAmount(amount, currency) {
        const numeric = Number(amount);
        const maxDigits = currency === 'BTC' ? 8 : 2;
        const formatted = Number.isFinite(numeric)
            ? new Intl.NumberFormat(undefined, { maximumFractionDigits: maxDigits }).format(numeric)
            : amount;
        return `${formatted} ${currency || ''}`.trim();
    }

    function statusClass(status) {
        if (status === 'Settled') return 'bg-success';
        if (status === 'Processing') return 'bg-warning text-dark';
        return 'bg-secondary';
    }

    function renderRows(data) {
        rows.replaceChildren();
        if (!data.payments || !data.payments.length) {
            const row = element('tr');
            const cell = element('td', 'text-secondary py-5 text-center', 'No MakePay payments found.');
            cell.colSpan = 8;
            row.append(cell);
            rows.append(row);
            return;
        }

        data.payments.forEach(payment => {
            const row = element('tr');

            const dateCell = element('td', 'text-nowrap');
            const time = element('time', '', new Intl.DateTimeFormat(undefined, {
                dateStyle: 'medium',
                timeStyle: 'short'
            }).format(new Date(payment.created)));
            time.dateTime = payment.created;
            dateCell.append(time);

            const invoiceCell = element('td', 'makepay-payment-meta');
            const invoiceLink = element('a', '', short(payment.invoiceId));
            invoiceLink.href = invoiceUrlTemplate.replace('__invoiceId__', encodeURIComponent(payment.invoiceId));
            invoiceLink.title = payment.invoiceId;
            invoiceCell.append(invoiceLink);
            if (payment.orderId) invoiceCell.append(element('div', 'small text-secondary text-break', payment.orderId));
            if (payment.paymentLinkUid) {
                invoiceCell.append(element('div', 'small text-secondary text-break', `Link ${short(payment.paymentLinkUid)}`));
            }

            const methodCell = element(
                'td',
                '',
                payment.paymentMethod === 'cash_app_onramp' ? 'Cash App' : 'Crypto');

            const assetCell = element('td');
            assetCell.append(element('div', '', displayAsset(payment.sellAsset)));
            if (payment.requiredSellAmount) {
                assetCell.append(element('div', 'small text-secondary text-nowrap', payment.requiredSellAmount));
            }

            const depositCell = element('td');
            if (payment.depositAddress) {
                const link = element('a', '', short(payment.depositAddress));
                link.href = `https://explorer.makecrypto.io/deposit/${encodeURIComponent(payment.depositAddress)}`;
                link.target = '_blank';
                link.rel = 'noreferrer noopener';
                link.title = payment.depositAddress;
                depositCell.append(link);
            } else if (payment.paymentRequest) {
                depositCell.append(element('span', '', short(payment.paymentRequest)));
            } else {
                depositCell.append(element('span', 'text-secondary', '-'));
            }

            const transactionCell = element('td');
            const transaction = payment.transactionIds || payment.deliveryId;
            if (transaction) {
                const detailsLink = element('a', '', short(transaction));
                detailsLink.href = paymentUrlTemplate.replace('__paymentId__', encodeURIComponent(payment.paymentId));
                detailsLink.title = transaction;
                transactionCell.append(detailsLink);
            } else {
                transactionCell.append(element('span', 'text-secondary', '-'));
            }

            const statusCell = element('td');
            statusCell.append(element('span', `badge rounded-pill ${statusClass(payment.status)}`, payment.status));
            if (payment.isSessionOnly) {
                statusCell.append(element('div', 'small text-secondary mt-1', 'Awaiting funds'));
            }
            if (payment.makePayStatus) {
                statusCell.append(element('div', 'small text-secondary mt-1', `MakePay: ${payment.makePayStatus}`));
            }

            const amountCell = element('td', 'text-end text-nowrap');
            const amount = element('span', '', displayAmount(payment.amount, payment.currency));
            amount.setAttribute('data-sensitive', '');
            amountCell.append(amount);
            if (payment.settlementAmount) {
                amountCell.append(element(
                    'div',
                    'small text-secondary',
                    `${payment.settlementAmount} ${payment.buyAsset || payment.currency || ''}`.trim()));
            }

            row.append(dateCell, invoiceCell, methodCell, assetCell, depositCell, transactionCell, statusCell, amountCell);
            rows.append(row);
        });
    }

    function render(data, cached) {
        const params = queryParams();
        hasRenderedData = true;
        renderRows(data);
        populateSelect('status', data.statusOptions, 'All Status', params.get('status'));
        populateSelect('asset', data.assetOptions, 'All Assets', params.get('asset'));
        populateSelect('network', data.networkOptions, 'All Networks', params.get('network'));
        fillForm(params);

        const start = data.totalCount ? data.skip + 1 : 0;
        const end = Math.min(data.skip + data.take, data.totalCount);
        pageSummary.textContent = `${start}–${end} of ${data.totalCount}`;
        previousButton.disabled = data.skip <= 0;
        nextButton.disabled = !data.hasMore;
        pagination.hidden = data.totalCount <= data.take && data.skip === 0;

        if (cached) {
            syncStatus.textContent = 'Showing saved payments while checking for updates…';
        } else if (data.isRefreshing) {
            syncStatus.textContent = 'Payments are up to date locally · checking open sessions in the background…';
        } else {
            const updated = new Intl.DateTimeFormat(undefined, {
                hour: 'numeric',
                minute: '2-digit',
                second: '2-digit'
            }).format(new Date(data.fetchedAt));
            syncStatus.textContent = `Updated ${updated}`;
        }
    }

    async function load(forceRefresh, pollAttempt = 0) {
        const currentRequest = ++requestNumber;
        const params = queryParams();
        if (forceRefresh) params.set('refresh', 'true');
        refreshButton.setAttribute('aria-busy', 'true');
        refreshButton.disabled = true;

        try {
            const url = new URL(dataUrl, window.location.origin);
            params.forEach((value, key) => url.searchParams.set(key, value));
            const response = await fetch(url, {
                credentials: 'same-origin',
                headers: { Accept: 'application/json' },
                cache: 'no-store'
            });
            const data = await response.json();
            if (!response.ok) throw new Error(data.error || 'Unable to load MakePay payments.');
            if (currentRequest !== requestNumber) return;

            const cacheParams = queryParams();
            writeCache(cacheParams, data);
            render(data, false);

            window.clearTimeout(pollTimer);
            if (data.isRefreshing && pollAttempt < 15) {
                pollTimer = window.setTimeout(() => load(false, pollAttempt + 1), 2000);
            }
        } catch (error) {
            if (currentRequest !== requestNumber) return;
            if (!hasRenderedData) {
                rows.replaceChildren();
                const row = element('tr');
                const cell = element('td', 'text-danger py-5 text-center', error.message);
                cell.colSpan = 8;
                row.append(cell);
                rows.append(row);
            }
            syncStatus.textContent = `${error.message} Saved payments remain visible when available.`;
        } finally {
            if (currentRequest === requestNumber) {
                refreshButton.removeAttribute('aria-busy');
                refreshButton.disabled = false;
            }
        }
    }

    function navigate(params) {
        const query = params.toString();
        window.history.replaceState({}, '', `${window.location.pathname}${query ? `?${query}` : ''}`);
        fillForm(params);
        const cached = readCache(params);
        if (cached) render(cached, true);
        load(false);
    }

    form.addEventListener('submit', event => {
        event.preventDefault();
        const values = new FormData(form);
        const params = new URLSearchParams();
        values.forEach((value, key) => {
            if (value) params.set(key, value.toString());
        });
        params.set('skip', '0');
        navigate(params);
    });

    clearButton.addEventListener('click', () => navigate(new URLSearchParams()));
    refreshButton.addEventListener('click', () => load(true));
    timeFilter.addEventListener('change', updateCustomRange);
    previousButton.addEventListener('click', () => {
        const params = queryParams();
        params.set('skip', Math.max(0, Number(params.get('skip') || 0) - 50).toString());
        navigate(params);
    });
    nextButton.addEventListener('click', () => {
        const params = queryParams();
        params.set('skip', (Number(params.get('skip') || 0) + 50).toString());
        navigate(params);
    });

    const initialParams = queryParams();
    fillForm(initialParams);
    const cached = readCache(initialParams);
    if (cached) render(cached, true);
    load(false);
})();
</script>
