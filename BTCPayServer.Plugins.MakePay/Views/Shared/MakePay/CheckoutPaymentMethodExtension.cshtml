@model BTCPayServer.Models.InvoicingModels.CheckoutModel

<style>
    .makepay-checkout {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    .makepay-checkout .makepay-option-list {
        display: grid;
        gap: .75rem;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }

    .makepay-checkout .makepay-option {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
        border: 1px solid var(--btcpay-border-color, #dee2e6);
        border-radius: .5rem;
        background: var(--btcpay-bg-tile, transparent);
        color: inherit;
        padding: .875rem;
        text-align: left;
        transition: border-color .15s ease, box-shadow .15s ease;
    }

    .makepay-checkout .makepay-option:hover,
    .makepay-checkout .makepay-option:focus,
    .makepay-checkout .makepay-option.active {
        border-color: var(--btcpay-primary, #1e7a44);
        box-shadow: 0 0 0 .125rem rgba(30, 122, 68, .15);
    }

    .makepay-checkout .makepay-option > span {
        display: grid !important;
        grid-template-columns: 2.5rem minmax(0, 1fr) auto;
        align-items: center;
        column-gap: .75rem;
        width: 100%;
        min-width: 0;
    }

    .makepay-checkout .makepay-option > span > .flex-grow-1 {
        min-width: 0;
        max-width: 100%;
    }

    .makepay-checkout .makepay-option-meta {
        flex: 0 0 auto;
        justify-self: end;
        margin-left: 0;
        white-space: nowrap;
    }

    .makepay-checkout .makepay-token-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        object-fit: contain;
        background: rgba(127, 127, 127, .12);
        flex: 0 0 auto;
    }

    .makepay-checkout .makepay-token-fallback {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--btcpay-primary, #1e7a44);
        color: #fff;
        font-weight: 700;
        flex: 0 0 auto;
    }

    .makepay-checkout .makepay-cash-app-icon {
        background: #00d64f;
        color: #fff;
        font-size: 1.35rem;
    }

    .makepay-checkout .makepay-search {
        border-radius: .5rem;
        max-width: 100%;
    }

    .makepay-checkout .makepay-back {
        text-decoration: none;
    }

    .makepay-checkout .makepay-selection-title {
        min-width: 0;
    }

    .makepay-checkout .makepay-cash-app-summary {
        display: flex;
        align-items: center;
        gap: .75rem;
        min-width: 0;
    }

    .makepay-checkout .makepay-cash-app-transfer {
        width: 100%;
        max-width: 30rem;
        margin: 0 auto;
    }

    .makepay-checkout .makepay-cash-app-qr {
        display: inline-flex;
        padding: .75rem;
        border-radius: .75rem;
        background: #fff;
        line-height: 0;
    }

    .makepay-checkout .makepay-cash-app-status {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        border: 1px solid var(--btcpay-border-color, #dee2e6);
        border-radius: 999px;
        padding: .35rem .7rem;
        font-size: .875rem;
    }

    .makepay-checkout .makepay-cash-app-status-dot {
        width: .5rem;
        height: .5rem;
        border-radius: 50%;
        background: #00d64f;
    }

    .makepay-checkout .makepay-cash-app-request {
        max-height: 4.5rem;
        overflow: hidden;
        font-size: .75rem;
    }

    @@media (max-width: 420px) {
        .makepay-checkout .makepay-option > span {
            grid-template-columns: 2.5rem minmax(0, 1fr);
        }

        .makepay-checkout .makepay-option-meta {
            grid-column: 2;
            justify-self: start;
            width: auto;
        }
    }
</style>

<template id="MakePayCheckout">
    <div class="payment-box makepay-checkout">
        <div v-if="error" class="alert alert-danger mb-3">{{ error }}</div>
        <div v-if="success" class="alert alert-success mb-3">{{ success }}</div>

        <div v-if="entryStep">
            <div v-if="isCashAppPayment">
                <button type="button"
                        class="btn btn-sm btn-link makepay-back p-0 mb-3"
                        v-on:click="exitCashApp"
                        :disabled="isBusy">
                    &larr; Back to payment methods
                </button>

                <div class="border rounded p-3 mb-3">
                    <div class="makepay-cash-app-summary">
                        <span class="makepay-token-fallback makepay-cash-app-icon">$</span>
                        <span class="min-w-0">
                            <span class="d-block fw-semibold">Pay with Cash App</span>
                            <span class="d-block text-muted small">Use your USD balance, linked card, or Cash App funding source.</span>
                        </span>
                    </div>
                </div>

                <div v-if="requestReceiptEmailFromCustomer" class="mb-3">
                    <label class="form-label" for="makepay-cash-app-receipt-email">Receipt email</label>
                    <input id="makepay-cash-app-receipt-email"
                           class="form-control"
                           type="email"
                           autocomplete="email"
                           v-model.trim="receiptEmail"
                           v-on:input="resetQuote" />
                </div>

                <div class="d-grid mb-3">
                    <button type="button"
                            class="btn btn-primary rounded-pill"
                            v-on:click="pay"
                            :disabled="payButtonDisabled">
                        {{ displayQuoteApproval ? 'Review Cash App quote' : 'Continue to Cash App' }}
                    </button>
                </div>
                <p class="small text-muted mb-0">
                    Available to eligible US payers. The final customer debit must not exceed $950.
                </p>
            </div>

            <div v-else-if="!selectedCurrency">
                <div v-if="cashAppOffered" class="mb-4">
                    <label class="form-label">Pay with Cash App</label>
                    <button type="button"
                            class="makepay-option"
                            v-on:click="openCashApp"
                            :disabled="isBusy">
                        <span class="d-flex align-items-center gap-3">
                            <span class="makepay-token-fallback makepay-cash-app-icon">$</span>
                            <span class="flex-grow-1 min-w-0">
                                <span class="d-block fw-semibold">Cash App</span>
                                <span class="d-block text-muted text-truncate">US payers · Pay securely in Cash App</span>
                            </span>
                            <span v-if="cashAppAmountLabel" class="makepay-option-meta text-muted small">
                                {{ cashAppAmountLabel }}
                            </span>
                        </span>
                    </button>
                </div>

                <label class="form-label" for="makepay-asset-search">Pay with</label>
                <input id="makepay-asset-search"
                       class="form-control makepay-search mb-3"
                       type="search"
                       autocomplete="off"
                       placeholder="Search asset"
                       v-model.trim="assetSearch" />

                <div class="makepay-option-list mb-3">
                    <button v-for="group in filteredAssetGroups"
                            :key="group.key"
                            type="button"
                            class="makepay-option"
                            v-on:click="selectCurrency(group.key)">
                        <span class="d-flex align-items-center gap-3">
                            <img v-if="group.logoURI" :src="group.logoURI" alt="" class="makepay-token-icon" />
                            <span v-else class="makepay-token-fallback">{{ group.ticker.slice(0, 2) }}</span>
                            <span class="flex-grow-1 min-w-0">
                                <span class="d-block fw-semibold">{{ group.ticker }}</span>
                                <span class="d-block text-muted text-truncate">{{ group.name }}</span>
                            </span>
                            <span class="makepay-option-meta text-muted small">
                                {{ group.networks.length }} {{ group.networks.length === 1 ? 'network' : 'networks' }}
                            </span>
                        </span>
                    </button>
                </div>
            </div>

            <div v-else-if="!selectedAsset">
                <button type="button"
                        class="btn btn-sm btn-link makepay-back p-0 mb-3"
                        v-on:click="changeAsset"
                        :disabled="isBusy">
                    &larr; Back to currencies
                </button>

                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="d-flex align-items-center gap-3 min-w-0">
                        <img v-if="selectedCurrencyGroup && selectedCurrencyGroup.logoURI" :src="selectedCurrencyGroup.logoURI" alt="" class="makepay-token-icon" />
                        <span v-else class="makepay-token-fallback">{{ selectedCurrency.slice(0, 2) }}</span>
                        <span class="makepay-selection-title">
                            <span class="d-block fw-semibold">Choose a network for {{ selectedCurrency }}</span>
                            <span class="d-block text-muted text-truncate">Select the exact network your wallet will send from.</span>
                        </span>
                    </div>
                </div>

                <div class="makepay-option-list mb-3">
                    <button v-for="token in selectedCurrencyNetworks"
                            :key="token.identifier"
                            type="button"
                            class="makepay-option"
                            v-on:click="selectNetwork(token.identifier)">
                        <span class="d-flex align-items-center gap-3">
                            <img v-if="token.chainLogoURI" :src="token.chainLogoURI" alt="" class="makepay-token-icon" />
                            <span v-else class="makepay-token-fallback">{{ token.chain.slice(0, 2) }}</span>
                            <span class="flex-grow-1 min-w-0">
                                <span class="d-block fw-semibold">{{ token.chain }} network</span>
                                <span class="d-block text-muted text-truncate">{{ networkName(token) }}</span>
                            </span>
                        </span>
                    </button>
                </div>
            </div>

            <div v-else>
                <button type="button"
                        class="btn btn-sm btn-link makepay-back p-0 mb-3"
                        v-on:click="changeNetwork"
                        :disabled="isBusy">
                    &larr; Back to networks
                </button>

                <div class="border rounded p-3 mb-3">
                    <div class="d-flex align-items-start gap-3">
                        <div class="d-flex align-items-center gap-3 min-w-0">
                            <img v-if="selectedToken && selectedToken.logoURI" :src="selectedToken.logoURI" alt="" class="makepay-token-icon" />
                            <span v-else class="makepay-token-fallback">{{ selectedCurrency.slice(0, 2) }}</span>
                            <span class="makepay-selection-title">
                                <span class="d-block fw-semibold">{{ selectedTokenLabel }}</span>
                                <span class="d-block text-muted text-truncate">{{ selectedToken ? networkName(selectedToken) : '' }}</span>
                            </span>
                        </div>
                    </div>
                </div>

                <div v-if="requestReceiptEmailFromCustomer" class="mb-3">
                    <label class="form-label" for="makepay-receipt-email">Receipt email</label>
                    <input id="makepay-receipt-email"
                           class="form-control"
                           type="email"
                           autocomplete="email"
                           v-model.trim="receiptEmail"
                           v-on:input="resetQuote" />
                </div>

                <div v-if="shouldCollectRefundAddress" class="mb-3">
                    <label class="form-label" for="makepay-refund-address">Refund address</label>
                    <input id="makepay-refund-address"
                           class="form-control"
                           v-model.trim="refundAddress"
                           v-on:input="resetQuote" />
                    <div class="form-text">
                        Used if this payment must be refunded on {{ selectedNetworkName }}.
                    </div>
                </div>

                <div class="d-grid mb-3">
                    <button type="button"
                            class="btn btn-primary rounded-pill"
                            v-on:click="pay"
                            :disabled="payButtonDisabled">
                        {{ displayQuoteApproval ? 'Review quote' : 'Pay now' }}
                    </button>
                </div>
            </div>
        </div>

        <div v-else-if="awaitingConfirmation">
            <button type="button"
                    class="btn btn-sm btn-link makepay-back p-0 mb-3"
                    v-on:click="backToPaymentDetails"
                    :disabled="isBusy">
                &larr; Back
            </button>

            <div class="border rounded p-3 mb-3">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div>
                        <div class="text-muted small">Pay with</div>
                        <div class="fw-semibold">{{ selectedTokenLabel }}</div>
                    </div>
                </div>

                <div class="text-muted small">{{ isCashAppPayment ? 'You pay' : 'You send' }}</div>
                <div class="h4 mb-2 text-break">{{ quoteAmount }} {{ quoteAssetLabel }}</div>

                <div class="d-flex align-items-center justify-content-between gap-3 small">
                    <span class="text-muted">{{ quoteCountdownLabel }}</span>
                    <button v-if="quoteExpired"
                            type="button"
                            class="btn btn-sm btn-link p-0"
                            v-on:click="quote"
                            :disabled="isBusy">
                        Refresh
                    </button>
                </div>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button type="button"
                        class="btn btn-primary rounded-pill"
                        v-on:click="pay"
                        :disabled="isBusy">
                    {{ reviewButtonText }}
                </button>
            </div>
        </div>

        <div v-else-if="paymentStarted && isCashAppPayment"
             class="makepay-cash-app-transfer text-center">
            <div class="makepay-cash-app-summary justify-content-center mb-3">
                <span class="makepay-token-fallback makepay-cash-app-icon">$</span>
                <span class="text-start">
                    <span class="d-block fw-semibold">Pay with Cash App</span>
                    <span class="d-block text-muted small">Complete the payment in Cash App</span>
                </span>
            </div>

            <div class="mb-3">
                <div class="text-muted small">Amount due</div>
                <div class="h4 mb-1">{{ quoteAmount }} USD</div>
                <div v-if="paymentCountdownLabel" class="small text-muted">{{ paymentCountdownLabel }}</div>
            </div>

            <div class="mb-3">
                <span class="makepay-cash-app-status">
                    <span class="makepay-cash-app-status-dot"></span>
                    {{ cashAppStatusLabel }}
                </span>
            </div>

            <div v-if="cashAppQrValue" class="mb-3">
                <div class="makepay-cash-app-qr">
                    <qrcode :value="cashAppQrValue" :options="qrOptions"></qrcode>
                </div>
                <div class="small text-muted mt-2">Scan with your phone to open Cash App</div>
            </div>

            <div v-if="cashAppOpenUrl" class="d-grid mb-3">
                <a class="btn btn-primary rounded-pill"
                   :href="cashAppOpenUrl"
                   target="_blank"
                   rel="noopener noreferrer">
                    Open Cash App
                </a>
            </div>

            <p class="small text-muted mb-2">
                Keep this invoice open. Payment status updates here automatically.
            </p>
            <code v-if="cashAppPaymentRequest"
                  class="makepay-cash-app-request d-block text-break user-select-all mb-2">{{ cashAppPaymentRequest }}</code>
            <button v-if="cashAppPaymentRequest"
                    type="button"
                    class="btn btn-sm btn-outline-secondary"
                    v-on:click="copyAddress">
                {{ copied ? 'Copied' : 'Copy payment request' }}
            </button>
        </div>

        <div v-else-if="paymentStarted" class="text-center">
            <div class="mb-3">
                <div class="text-muted small">Send exactly</div>
                <div class="h4 mb-0 text-break">{{ quoteAmount }} {{ quoteAssetLabel }}</div>
                <div v-if="paymentCountdownLabel" class="small text-muted mt-1">{{ paymentCountdownLabel }}</div>
            </div>

            <div class="mb-3">
                <qrcode v-if="qrValue" :value="qrValue" :options="qrOptions"></qrcode>
            </div>

            <div class="text-muted small mb-2">Payment address</div>
            <code class="d-block text-break user-select-all mb-2">{{ depositAddress }}</code>
            <button type="button" class="btn btn-sm btn-outline-secondary" v-on:click="copyAddress">
                {{ copied ? 'Copied' : 'Copy address' }}
            </button>
        </div>

        <div v-if="status && !isCashAppPayment" class="mt-3 small text-muted text-center">
            Status: {{ status }}
        </div>

        <div v-if="isBusy" class="text-center py-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
</template>

<script src="~/vendor/vue-qrcode/vue-qrcode.min.js"></script>
<script>
(function () {
    if (typeof Vue === 'undefined') {
        return;
    }

    Vue.component('MakePayCheckout', {
        props: ['model'],
        template: '#MakePayCheckout',
        components: {
            qrcode: window.VueQrcode
        },
        data: function () {
            return {
                tokens: [],
                capabilities: null,
                selectedPaymentMethod: 'crypto',
                selectedCurrency: '',
                selectedAsset: '',
                assetSearch: '',
                receiptEmail: '',
                refundAddress: '',
                quoteSessionId: '',
                quoteAmount: '',
                quoteAsset: '',
                quoteKey: '',
                quoteExpiresAtMs: 0,
                depositAddress: '',
                qrValue: '',
                cashAppQrCodeUrl: '',
                cashAppDeepLink: '',
                cashAppPaymentRequest: '',
                paymentExpiresAtMs: 0,
                status: '',
                error: '',
                success: '',
                isBusy: false,
                autoRefreshInFlight: false,
                awaitingConfirmation: false,
                paymentStarted: false,
                copied: false,
                pollTimer: null,
                clockTimer: null,
                nowMs: Date.now(),
                qrOptions: {
                    width: 240,
                    margin: 1,
                    color: {
                        dark: '#000000',
                        light: '#ffffff'
                    }
                }
            };
        },
        computed: {
            apiBase: function () {
                return '/api/plugins/makepay/' +
                    encodeURIComponent(this.model.makePayStoreId) +
                    '/' +
                    encodeURIComponent(this.model.invoiceId);
            },
            cashAppApiBase: function () {
                try {
                    var target = new URL(
                        String(this.model.makePayPaymentLinkUrl || this.model.makePayCheckoutBaseUrl || ''),
                        window.location.href
                    );
                    if (target.protocol !== 'https:' && target.protocol !== 'http:') {
                        return '';
                    }

                    var uid = String(this.model.makePayPaymentLinkUid || '').trim();
                    return uid
                        ? target.origin +
                            '/api/public/payment-links/' +
                            encodeURIComponent(uid) +
                            '/btcpay-checkout'
                        : '';
                } catch (err) {
                    return '';
                }
            },
            entryStep: function () {
                return !this.awaitingConfirmation && !this.paymentStarted;
            },
            isCashAppPayment: function () {
                return this.selectedPaymentMethod === 'cash_app_onramp';
            },
            displayQuoteApproval: function () {
                return this.model.makePayDisplayQuoteApproval !== false;
            },
            requestReceiptEmailFromCustomer: function () {
                return this.model.makePayRequestReceiptEmailFromCustomer === true;
            },
            settlementAssetKey: function () {
                return this.normalizeAssetKey(this.model.makePaySettlementAsset || '');
            },
            isAnonymous: function () {
                return this.model.makePayIsAnonymous === true;
            },
            cashAppCapability: function () {
                return this.capabilities && this.capabilities.cashAppOnramp
                    ? this.capabilities.cashAppOnramp
                    : null;
            },
            cashAppOffered: function () {
                return this.cashAppCapability && this.cashAppCapability.offered === true;
            },
            cashAppAmountLabel: function () {
                var amount = this.cashAppCapability && Number(this.cashAppCapability.amountUsd);
                return Number.isFinite(amount) && amount > 0
                    ? '$' + amount.toFixed(2)
                    : '';
            },
            cashAppQrValue: function () {
                return this.cashAppDeepLink ||
                    this.cashAppQrCodeUrl ||
                    this.cashAppPaymentRequest ||
                    '';
            },
            cashAppOpenUrl: function () {
                var value = String(this.cashAppDeepLink || '').trim();
                if (!value) {
                    return '';
                }

                try {
                    var target = new URL(value);
                    return target.protocol === 'https:' || target.protocol === 'cashapp:'
                        ? target.toString()
                        : '';
                } catch (err) {
                    return '';
                }
            },
            cashAppStatusLabel: function () {
                var labels = {
                    quoted: 'Quote ready',
                    awaiting_deposit: 'Waiting for Cash App',
                    pending: 'Payment pending',
                    deposit_received: 'Payment received',
                    swapping: 'Converting payment',
                    sending: 'Sending settlement',
                    complete: 'Payment complete',
                    expired: 'Payment expired',
                    failed: 'Payment failed',
                    cancelled: 'Payment cancelled'
                };
                return labels[this.status] || 'Waiting for payment';
            },
            refundAddressMode: function () {
                return this.model.makePayRefundAddressMode === 'payer_entered'
                    ? 'payer_entered'
                    : 'merchant_wallet';
            },
            allowedAssetKeys: function () {
                var self = this;
                return String(this.model.makePayAllowedAssetIdentifiers || '')
                    .split(/[,\n\r]+/)
                    .map(function (value) { return self.normalizeAssetKey(value); })
                    .filter(function (value) { return value.length > 0; });
            },
            merchantRefundChains: function () {
                var chains = Array.isArray(this.model.makePayMerchantRefundChains)
                    ? this.model.makePayMerchantRefundChains
                    : [];
                return chains
                    .map(function (chain) { return String(chain || '').trim().toUpperCase(); })
                    .filter(function (chain) { return chain.length > 0; });
            },
            assetGroups: function () {
                var groups = new Map();
                var names = {
                    USDC: 'USD Coin',
                    USDT: 'Tether USD'
                };

                this.tokens.forEach(function (token) {
                    var key = (token.ticker || token.symbol || token.identifier).toUpperCase();
                    var name = names[key] || token.name || key;
                    if (!groups.has(key)) {
                        groups.set(key, {
                            key: key,
                            ticker: key,
                            name: name,
                            logoURI: token.logoURI,
                            networks: []
                        });
                    }

                    var group = groups.get(key);
                    group.networks.push(token);
                    if (!group.logoURI && token.logoURI) {
                        group.logoURI = token.logoURI;
                    }
                    if (names[key]) {
                        group.name = names[key];
                    }
                    if (group.name === key && token.name) {
                        group.name = token.name;
                    }
                });

                var priority = ['BTC', 'ETH', 'SOL', 'USDT', 'USDC'];
                return Array.from(groups.values()).sort(function (a, b) {
                    var left = priority.indexOf(a.key);
                    var right = priority.indexOf(b.key);
                    if (left !== -1 || right !== -1) {
                        return (left === -1 ? 999 : left) - (right === -1 ? 999 : right);
                    }
                    return a.key.localeCompare(b.key);
                });
            },
            filteredAssetGroups: function () {
                var query = this.assetSearch.toLowerCase();
                if (!query) {
                    return this.assetGroups;
                }

                return this.assetGroups.filter(function (group) {
                    return group.key.toLowerCase().indexOf(query) >= 0 ||
                        String(group.name || '').toLowerCase().indexOf(query) >= 0;
                });
            },
            selectedCurrencyGroup: function () {
                var selected = this.selectedCurrency;
                return this.assetGroups.find(function (group) {
                    return group.key === selected;
                }) || null;
            },
            selectedCurrencyNetworks: function () {
                return this.selectedCurrencyGroup
                    ? this.selectedCurrencyGroup.networks
                    : [];
            },
            selectedToken: function () {
                var selected = this.selectedAsset;
                return this.tokens.find(function (token) {
                    return token.identifier === selected;
                }) || null;
            },
            selectedTokenLabel: function () {
                if (this.isCashAppPayment) {
                    return 'Cash App';
                }
                if (!this.selectedToken) {
                    return this.selectedAsset;
                }

                return this.selectedToken.ticker + ' on ' + this.selectedToken.chain;
            },
            selectedNetworkName: function () {
                return this.selectedToken
                    ? this.networkName(this.selectedToken)
                    : 'the selected network';
            },
            shouldCollectRefundAddress: function () {
                if (this.isCashAppPayment || !this.selectedToken) {
                    return false;
                }

                return this.refundAddressMode === 'payer_entered' ||
                    (this.selectedToken.requiresPayerRefundAddress && !this.hasMerchantRefundAddress(this.selectedToken));
            },
            paymentRefundAddress: function () {
                return this.shouldCollectRefundAddress
                    ? this.refundAddress.trim()
                    : '';
            },
            quoteAssetLabel: function () {
                if (this.isCashAppPayment) {
                    return 'USD';
                }
                return this.shortAssetLabel(this.quoteAsset || this.selectedAsset);
            },
            quoteSecondsRemaining: function () {
                if (!this.quoteExpiresAtMs) {
                    return 0;
                }
                return Math.max(0, Math.ceil((this.quoteExpiresAtMs - this.nowMs) / 1000));
            },
            quoteExpired: function () {
                return this.awaitingConfirmation && this.quoteSecondsRemaining <= 0;
            },
            quoteCountdownLabel: function () {
                return this.quoteExpired
                    ? 'Quote expired'
                    : 'Quote refreshes in ' + this.formatDuration(this.quoteSecondsRemaining);
            },
            paymentSecondsRemaining: function () {
                if (!this.paymentExpiresAtMs) {
                    return 0;
                }
                return Math.max(0, Math.ceil((this.paymentExpiresAtMs - this.nowMs) / 1000));
            },
            paymentCountdownLabel: function () {
                if (!this.paymentExpiresAtMs) {
                    return '';
                }
                return this.paymentSecondsRemaining > 0
                    ? 'Payment expires in ' + this.formatDuration(this.paymentSecondsRemaining)
                    : 'Payment window expired';
            },
            reviewButtonText: function () {
                if (this.quoteExpired) {
                    return 'Refreshing quote...';
                }
                return this.isCashAppPayment ? 'Continue to Cash App' : 'Confirm and pay';
            },
            payButtonDisabled: function () {
                return this.isBusy ||
                    (!this.isCashAppPayment && !this.selectedAsset) ||
                    (this.shouldCollectRefundAddress && !this.refundAddress.trim()) ||
                    this.status === 'complete' ||
                    (!this.isCashAppPayment && this.tokens.length === 0);
            }
        },
        mounted: function () {
            var self = this;
            this.clockTimer = setInterval(function () {
                self.nowMs = Date.now();
                self.autoRefreshQuoteIfNeeded();
            }, 1000);
            this.initializeCheckout();
        },
        beforeDestroy: function () {
            this.stopPolling();
            if (this.clockTimer) {
                clearInterval(this.clockTimer);
                this.clockTimer = null;
            }
        },
        methods: {
            initializeCheckout: async function () {
                var restored = await this.restoreExistingSession(false);
                if (restored && this.paymentStarted) {
                    this.error = '';
                    return;
                }

                await this.loadCapabilities();
                await this.loadTokens();
            },
            loadCapabilities: async function () {
                try {
                    var response = await fetch(this.apiBase + '/capabilities', { cache: 'no-store' });
                    var payload = await this.parseFetchPayload(response, 'Unable to load payment methods.');
                    this.capabilities = response.ok && payload ? payload : null;
                } catch (err) {
                    this.capabilities = null;
                }
            },
            loadTokens: async function () {
                this.error = '';
                this.isBusy = true;
                try {
                    var response = await fetch(this.apiBase + '/tokens', { cache: 'no-store' });
                    var payload = await this.parseFetchPayload(response, 'Unable to load currencies.');
                    if (!response.ok || !Array.isArray(payload)) {
                        throw new Error(payload && payload.error ? payload.error : 'Unable to load currencies.');
                    }
                    var self = this;
                    this.tokens = payload
                        .filter(function (token) { return token && token.identifier; })
                        .map(function (token) {
                            return {
                                identifier: String(token.identifier),
                                ticker: String(token.ticker || token.symbol || ''),
                                symbol: String(token.symbol || token.ticker || ''),
                                name: String(token.name || token.ticker || token.identifier),
                                chain: String(token.chain || token.network || token.chainId || ''),
                                chainId: String(token.chainId || ''),
                                network: String(token.network || token.chain || token.chainId || ''),
                                logoURI: String(token.logoURI || token.logoUrl || token.icon || ''),
                                chainLogoURI: String(
                                    token.chainLogoURI ||
                                    token.chainLogoUrl ||
                                    token.chainIconURI ||
                                    token.chainIconUrl ||
                                    token.networkLogoURI ||
                                    token.networkLogoUrl ||
                                    token.networkIconURI ||
                                    token.networkIconUrl ||
                                    ''
                                ),
                                requiresPayerRefundAddress:
                                    token.requiresPayerRefundAddress === true ||
                                    token.requires_payer_refund_address === true
                            };
                        })
                        .filter(function (token) {
                            return self.matchesAllowedAsset(token) &&
                                !self.isSettlementAsset(token);
                        })
                        .sort(function (a, b) {
                            if (a.ticker !== b.ticker) {
                                return a.ticker.localeCompare(b.ticker);
                            }
                            return a.chain.localeCompare(b.chain);
                        });
                    if (this.tokens.length === 0 && !this.cashAppOffered) {
                        this.error = 'No MakePay currencies are available with the current settings.';
                    }
                    this.syncSelectedCurrencyFromAsset();
                } catch (err) {
                    if (!this.cashAppOffered) {
                        this.error = err && err.message ? err.message : 'Unable to load currencies.';
                    }
                } finally {
                    this.isBusy = false;
                }
            },
            parseFetchPayload: async function (response, fallbackMessage) {
                var text = await response.text();
                if (!text.trim()) {
                    return {};
                }

                try {
                    return JSON.parse(text);
                } catch (err) {
                    throw new Error(fallbackMessage || 'MakePay checkout is temporarily unavailable. Please retry in a few seconds.');
                }
            },
            sessionPayload: function (payload) {
                return payload && payload.session ? payload.session : payload;
            },
            restoreExistingSession: async function (showErrors) {
                this.isBusy = true;
                try {
                    var response = await fetch(this.apiBase + '/session', { cache: 'no-store' });
                    var payload = await this.parseFetchPayload(response, 'Unable to load active MakePay payment.');
                    if (!response.ok) {
                        throw new Error(payload && payload.error ? payload.error : 'Unable to load active MakePay payment.');
                    }

                    var session = this.sessionPayload(payload);
                    if (!session || !session.sessionId) {
                        return null;
                    }

                    this.quoteSessionId = String(session.sessionId);
                    this.selectedPaymentMethod =
                        session.paymentMethod === 'cash_app_onramp' || session.cashApp
                            ? 'cash_app_onramp'
                            : 'crypto';
                    if (!this.isCashAppPayment) {
                        this.selectedAsset = String(session.selectedSellAsset || session.sellAsset || this.selectedAsset || '');
                        this.syncSelectedCurrencyFromAsset();
                    }
                    this.awaitingConfirmation = false;
                    this.paymentStarted = !!(session.deposit || session.cashApp);
                    this.applyPaymentState(session);
                    this.startPolling(session.sessionId);
                    return session;
                } catch (err) {
                    if (showErrors) {
                        this.error = err && err.message ? err.message : 'Unable to load active MakePay payment.';
                    }
                    return null;
                } finally {
                    this.isBusy = false;
                }
            },
            selectCurrency: function (currency) {
                this.selectedPaymentMethod = 'crypto';
                this.selectedCurrency = currency;
                this.selectedAsset = '';
                this.assetSearch = '';
                this.refundAddress = '';
                this.resetQuote();
            },
            openCashApp: async function () {
                if (!this.cashAppOffered) {
                    return;
                }

                this.resetQuote();
                this.selectedPaymentMethod = 'cash_app_onramp';
                this.selectedCurrency = '';
                this.selectedAsset = '';
                this.refundAddress = '';

                if (!this.cashAppApiBase) {
                    this.error = 'Cash App checkout is temporarily unavailable.';
                    return;
                }

                if (!this.requestReceiptEmailFromCustomer) {
                    await this.pay();
                }
            },
            exitCashApp: function () {
                this.resetQuote();
                this.selectedPaymentMethod = 'crypto';
            },
            selectNetwork: function (identifier) {
                this.selectedPaymentMethod = 'crypto';
                this.selectedAsset = identifier;
                this.syncSelectedCurrencyFromAsset();
                this.refundAddress = '';
                this.resetQuote();
            },
            changeAsset: function () {
                this.selectedCurrency = '';
                this.selectedAsset = '';
                this.refundAddress = '';
                this.resetQuote();
            },
            changeNetwork: function () {
                this.selectedAsset = '';
                this.refundAddress = '';
                this.resetQuote();
            },
            backToPaymentDetails: function () {
                this.awaitingConfirmation = false;
                this.error = '';
            },
            networkName: function (token) {
                var names = {
                    ARB: 'Arbitrum Chain',
                    AVAX: 'Avalanche Chain',
                    BASE: 'Base Chain',
                    BSC: 'BNB Chain',
                    BTC: 'Bitcoin',
                    ETH: 'Ethereum Chain',
                    GNO: 'Gnosis Chain',
                    NEAR: 'NEAR Chain',
                    OP: 'Optimism Chain',
                    POL: 'Polygon Chain',
                    SOL: 'Solana Chain',
                    TON: 'TON Chain',
                    TRON: 'Tron Chain'
                };
                return names[token.chain] || token.network || token.chain || token.chainId || 'Network';
            },
            hasMerchantRefundAddress: function (token) {
                var chain = String(token && token.chain || '').trim().toUpperCase();
                return chain.length > 0 && this.merchantRefundChains.indexOf(chain) >= 0;
            },
            shortAssetLabel: function (value) {
                var asset = String(value || '').trim();
                if (this.selectedToken && this.selectedToken.ticker && (
                    !asset ||
                    asset === this.selectedToken.identifier ||
                    asset.indexOf(this.selectedToken.ticker) >= 0)) {
                    return this.selectedToken.ticker || asset;
                }

                var withoutChain = asset.indexOf('.') >= 0
                    ? asset.substring(asset.indexOf('.') + 1)
                    : asset;
                return withoutChain.split('-')[0] || asset;
            },
            tokenKeys: function (token) {
                var identifier = this.normalizeAssetKey(token.identifier);
                var ticker = this.normalizeAssetKey(token.ticker || token.symbol);
                var network = this.normalizeAssetKey(token.network || token.chain);
                var name = this.normalizeAssetKey(token.name);
                var keys = [identifier, ticker, name];
                if (ticker && network) {
                    keys.push(ticker + '-' + network);
                    keys.push(ticker + '.' + network);
                    keys.push(network + '-' + ticker);
                    keys.push(network + '.' + ticker);
                }
                return keys.filter(function (key) { return key.length > 0; });
            },
            normalizeAssetKey: function (value) {
                return String(value || '')
                    .trim()
                    .toUpperCase()
                    .replace(/\s*([-.:])\s*/g, '$1');
            },
            matchesAllowedAsset: function (token) {
                if (this.allowedAssetKeys.length === 0) {
                    return true;
                }

                var keys = this.tokenKeys(token);
                return this.allowedAssetKeys.some(function (allowed) {
                    return keys.some(function (key) {
                        return key === allowed || key.indexOf(allowed) >= 0 || allowed.indexOf(key) >= 0;
                    });
                });
            },
            syncSelectedCurrencyFromAsset: function () {
                if (!this.selectedAsset || this.selectedCurrency) {
                    return;
                }

                var token = this.selectedToken;
                if (token) {
                    this.selectedCurrency = (token.ticker || token.symbol || token.identifier).toUpperCase();
                }
            },
            isSettlementAsset: function (token) {
                return this.settlementAssetKey &&
                    this.normalizeAssetKey(token.identifier) === this.settlementAssetKey;
            },
            formatDuration: function (seconds) {
                var value = Math.max(0, Number(seconds) || 0);
                var minutes = Math.floor(value / 60);
                var remaining = value % 60;
                return minutes + ':' + String(remaining).padStart(2, '0');
            },
            parseDateMs: function (value) {
                var parsed = Date.parse(String(value || ''));
                return Number.isFinite(parsed) ? parsed : 0;
            },
            resolveQuoteExpiry: function (payload) {
                var quote = payload && payload.quote ? payload.quote : {};
                var refreshInSeconds = Number(quote.refreshInSeconds || quote.refresh_in_seconds || 0);
                var updatedAtMs = this.parseDateMs(quote.updatedAt || quote.updated_at);
                if (refreshInSeconds > 0 && updatedAtMs > 0) {
                    return updatedAtMs + refreshInSeconds * 1000;
                }

                var cashAppExpiresAtMs = this.parseDateMs(
                    payload && payload.cashApp &&
                    (payload.cashApp.paymentWindowExpiresAt || payload.cashApp.expiresAt)
                );
                if (cashAppExpiresAtMs) {
                    return cashAppExpiresAtMs;
                }

                var expiresAtMs = this.parseDateMs(payload && payload.expiresAt);
                return expiresAtMs || Date.now() + 60000;
            },
            currentQuoteKey: function () {
                return [
                    this.selectedPaymentMethod,
                    this.selectedAsset,
                    this.receiptEmailForQuote(),
                    this.paymentRefundAddress,
                    this.refundAddressMode
                ].join('|');
            },
            resetQuote: function () {
                this.quoteSessionId = '';
                this.quoteAmount = '';
                this.quoteAsset = '';
                this.quoteKey = '';
                this.quoteExpiresAtMs = 0;
                this.depositAddress = '';
                this.qrValue = '';
                this.cashAppQrCodeUrl = '';
                this.cashAppDeepLink = '';
                this.cashAppPaymentRequest = '';
                this.paymentExpiresAtMs = 0;
                this.status = '';
                this.error = '';
                this.success = '';
                this.awaitingConfirmation = false;
                this.paymentStarted = false;
                this.copied = false;
                this.stopPolling();
            },
            receiptEmailForQuote: function () {
                return this.requestReceiptEmailFromCustomer
                    ? this.receiptEmail.trim()
                    : '';
            },
            validateEmail: function (value) {
                return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(value);
            },
            validateInput: function () {
                if (this.isCashAppPayment && !this.cashAppApiBase) {
                    this.error = 'Cash App checkout is temporarily unavailable.';
                    return false;
                }

                if (!this.isCashAppPayment && !this.selectedAsset) {
                    this.error = this.selectedCurrency ? 'Select a network.' : 'Select a currency.';
                    return false;
                }

                var email = this.receiptEmailForQuote();
                if (this.requestReceiptEmailFromCustomer && (!email || !this.validateEmail(email))) {
                    this.error = this.requestReceiptEmailFromCustomer
                        ? 'Enter a valid receipt email.'
                        : 'Set a default receipt email in the MakePay settings.';
                    return false;
                }

                if (this.shouldCollectRefundAddress && !this.paymentRefundAddress) {
                    this.error = 'Enter a refund address for ' +
                        (this.selectedToken && this.selectedToken.chain ? this.selectedToken.chain : 'the selected network') +
                        ' before continuing.';
                    return false;
                }

                return true;
            },
            buildPaymentBody: function () {
                if (this.isCashAppPayment) {
                    var cashAppBody = {
                        paymentMethod: 'cash_app_onramp',
                        provider: 'flashnet'
                    };
                    if (this.requestReceiptEmailFromCustomer) {
                        cashAppBody.receiptEmail = this.receiptEmailForQuote();
                    }
                    return cashAppBody;
                }

                var body = {
                    sellAsset: this.selectedAsset,
                    paymentMethod: 'crypto'
                };

                if (this.requestReceiptEmailFromCustomer) {
                    body.receiptEmail = this.receiptEmailForQuote();
                }

                if (this.paymentRefundAddress) {
                    body.refundAddress = this.paymentRefundAddress;
                    body.sourceAddress = this.paymentRefundAddress;
                }

                return body;
            },
            paymentApiUrl: function (operation) {
                return this.isCashAppPayment
                    ? this.cashAppApiBase + '/' + operation
                    : this.apiBase + '/' + operation;
            },
            pay: async function () {
                if (this.awaitingConfirmation) {
                    if (this.quoteExpired || this.quoteKey !== this.currentQuoteKey()) {
                        await this.quote(true);
                        return;
                    }
                    await this.startPayment();
                    return;
                }

                if (!this.validateInput()) {
                    return;
                }

                var payload = await this.quote(this.displayQuoteApproval);
                if (payload && !this.displayQuoteApproval) {
                    await this.startPayment();
                }
            },
            autoRefreshQuoteIfNeeded: async function () {
                if (!this.awaitingConfirmation ||
                    this.paymentStarted ||
                    !this.quoteExpired ||
                    this.isBusy ||
                    this.autoRefreshInFlight) {
                    return;
                }

                this.autoRefreshInFlight = true;
                try {
                    await this.quote(true);
                } finally {
                    this.autoRefreshInFlight = false;
                }
            },
            quote: async function (showConfirmation) {
                if (!this.validateInput()) {
                    return null;
                }

                this.error = '';
                this.isBusy = true;
                try {
                    var response = await fetch(this.paymentApiUrl('quote'), {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: this.isCashAppPayment ? 'omit' : 'same-origin',
                        body: JSON.stringify(this.buildPaymentBody())
                    });
                    var payload = await this.parseFetchPayload(response, 'Unable to quote payment.');
                    if (!response.ok || !payload.sessionId) {
                        throw new Error(payload && payload.error ? payload.error : 'Unable to quote payment.');
                    }
                    this.quoteSessionId = payload.sessionId;
                    this.quoteKey = this.currentQuoteKey();
                    this.status = payload.status || 'quoted';
                    this.applyQuotedAmounts(payload);
                    this.applyCashAppState(payload.cashApp);
                    this.quoteExpiresAtMs = this.resolveQuoteExpiry(payload);
                    this.awaitingConfirmation = showConfirmation !== false;
                    this.nowMs = Date.now();
                    return payload;
                } catch (err) {
                    this.error = err && err.message ? err.message : 'Unable to quote payment.';
                    this.awaitingConfirmation = false;
                    return null;
                } finally {
                    this.isBusy = false;
                }
            },
            startPayment: async function () {
                if (!this.quoteSessionId) {
                    return;
                }

                this.error = '';
                this.isBusy = true;
                try {
                    var body = this.isCashAppPayment
                        ? { sessionId: this.quoteSessionId }
                        : this.buildPaymentBody();
                    body.sessionId = this.quoteSessionId;
                    var response = await fetch(this.paymentApiUrl('start'), {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: this.isCashAppPayment ? 'omit' : 'same-origin',
                        body: JSON.stringify(body)
                    });
                    var payload = await this.parseFetchPayload(response, 'Unable to start payment.');
                    if (!response.ok || !payload.sessionId) {
                        throw new Error(payload && payload.error ? payload.error : 'Unable to start payment.');
                    }
                    this.awaitingConfirmation = false;
                    this.paymentStarted = true;
                    this.applyPaymentState(payload);
                    this.startPolling(payload.sessionId);
                } catch (err) {
                    var message = err && err.message ? err.message : 'Unable to start payment.';
                    if (message.toLowerCase().indexOf('already been used') >= 0) {
                        var restored = await this.restoreExistingSession(true);
                        if (restored) {
                            this.error = '';
                            return;
                        }
                    }
                    this.error = message;
                } finally {
                    this.isBusy = false;
                }
            },
            applyQuotedAmounts: function (payload) {
                var cashAppAmount = payload.cashApp && Number(payload.cashApp.amountFiatUsd);
                if (Number.isFinite(cashAppAmount) && cashAppAmount > 0) {
                    this.quoteAmount = cashAppAmount.toFixed(2);
                    this.quoteAsset = 'USD';
                    return;
                }

                var payableAmount = payload.payable && (payload.payable.requiredSellAmount || payload.payable.displayRequiredSellAmount);
                if (payableAmount) {
                    this.quoteAmount = String(payableAmount);
                    this.quoteAsset =
                        payload.payable && payload.payable.sellAsset
                            ? String(payload.payable.sellAsset)
                            : (this.quoteAsset || this.selectedAsset);
                    return;
                }

                if (payload.whatToSend) {
                    if (!this.quoteAmount && payload.whatToSend.amount) {
                        this.quoteAmount = String(payload.whatToSend.amount);
                    }
                    if (!this.quoteAsset && payload.whatToSend.asset) {
                        this.quoteAsset = String(payload.whatToSend.asset);
                    }
                }
            },
            applyCashAppState: function (cashApp) {
                if (!cashApp) {
                    return;
                }

                this.selectedPaymentMethod = 'cash_app_onramp';
                this.cashAppDeepLink = String(cashApp.deepLink || this.cashAppDeepLink || '');
                this.cashAppQrCodeUrl = String(cashApp.qrCodeUrl || this.cashAppQrCodeUrl || '');
                this.cashAppPaymentRequest = String(cashApp.paymentRequest || this.cashAppPaymentRequest || '');
                this.depositAddress = this.cashAppPaymentRequest || this.depositAddress;
                this.qrValue = this.cashAppQrValue || this.qrValue;

                var cashAppAmount = Number(cashApp.amountFiatUsd);
                if (Number.isFinite(cashAppAmount) && cashAppAmount > 0) {
                    this.quoteAmount = cashAppAmount.toFixed(2);
                    this.quoteAsset = 'USD';
                }

                this.paymentExpiresAtMs =
                    this.parseDateMs(cashApp.paymentWindowExpiresAt || cashApp.expiresAt) ||
                    this.paymentExpiresAtMs;
            },
            applyPaymentState: function (payload) {
                payload = this.sessionPayload(payload) || {};
                if (payload.sessionId) {
                    this.quoteSessionId = String(payload.sessionId);
                }
                if (payload.paymentMethod === 'cash_app_onramp' || payload.cashApp) {
                    this.selectedPaymentMethod = 'cash_app_onramp';
                }
                if (!this.isCashAppPayment && payload.selectedSellAsset && !this.selectedAsset) {
                    this.selectedAsset = String(payload.selectedSellAsset);
                    this.syncSelectedCurrencyFromAsset();
                }
                this.status = payload.status || this.status;
                this.applyQuotedAmounts(payload);
                this.paymentExpiresAtMs = this.parseDateMs(payload.expiresAt) || this.paymentExpiresAtMs;
                if (payload.deposit) {
                    this.depositAddress = payload.deposit.address || this.depositAddress;
                    this.qrValue =
                        (payload.deposit.qr && (payload.deposit.qr.withAmount || payload.deposit.qr.addressOnly)) ||
                        payload.deposit.qrData ||
                        payload.deposit.uri ||
                        this.depositAddress;
                }
                if (payload.cashApp) {
                    this.applyCashAppState(payload.cashApp);
                }
                if (this.status === 'complete') {
                    this.success = 'Payment complete.';
                    this.stopPolling();
                    setTimeout(function () { window.location.reload(); }, 1500);
                } else if (['expired', 'failed', 'cancelled'].indexOf(this.status) >= 0) {
                    this.stopPolling();
                }
            },
            startPolling: function (sessionId) {
                var self = this;
                this.stopPolling();
                this.pollTimer = setInterval(function () {
                    self.pollStatus(sessionId);
                }, 5000);
                this.pollStatus(sessionId);
            },
            stopPolling: function () {
                if (this.pollTimer) {
                    clearInterval(this.pollTimer);
                    this.pollTimer = null;
                }
            },
            pollStatus: async function (sessionId) {
                try {
                    var response = await fetch(
                        this.apiBase + '/status?sessionId=' + encodeURIComponent(sessionId),
                        { cache: 'no-store' }
                    );
                    var payload = await this.parseFetchPayload(response, 'Unable to poll MakePay status.');
                    if (response.ok) {
                        this.applyPaymentState(payload);
                    }
                } catch (err) {
                    console.warn('Unable to poll MakePay status', err);
                }
            },
            copyAddress: function () {
                var self = this;
                if (navigator.clipboard && this.depositAddress) {
                    navigator.clipboard.writeText(this.depositAddress).then(function () {
                        self.copied = true;
                        setTimeout(function () { self.copied = false; }, 1500);
                    });
                }
            }
        }
    });
})();
</script>
