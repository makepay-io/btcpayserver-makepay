@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Client
@using BTCPayServer.Data
@using BTCPayServer.Payments
@using BTCPayServer.Plugins.MakePay
@using BTCPayServer.Plugins.MakePay.PaymentHandler
@using BTCPayServer.Services.Stores
@inject IScopeProvider ScopeProvider
@inject StoreRepository StoreRepository
@inject PaymentMethodHandlerDictionary Handlers
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
    MakePayPaymentMethodConfig? config = null;
    var status = "pending";
    var controller = Context.Request.RouteValues["controller"]?.ToString();
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var isMakePayActive =
        ViewData.IsCategory("MakePay") ||
        string.Equals(controller, "MakePay", StringComparison.OrdinalIgnoreCase) ||
        requestPath.Contains("/makepay", StringComparison.OrdinalIgnoreCase);

    if (!string.IsNullOrEmpty(storeId))
    {
        var store = await StoreRepository.FindStore(storeId);
        if (store != null)
        {
            config = store.GetPaymentMethodConfig<MakePayPaymentMethodConfig>(
                MakePayPlugin.MakePayPaymentMethodId,
                Handlers);
        }

        if (config is not null)
        {
            status = config.Enabled ? "enabled" : "disabled";
        }
    }
}
@if (!string.IsNullOrEmpty(storeId))
{
    <li class="nav-item">
        <a permission="@Policies.CanModifyStoreSettings"
           layout-menu-item="MakePay"
           asp-controller="MakePay"
           asp-action="Payments"
           asp-route-storeId="@storeId">
            <span class="me-2 btcpay-status btcpay-status--@status"></span>
            <span>MakePay</span>
        </a>
    </li>
    @if (isMakePayActive)
    {
        <li class="nav-item nav-item-sub">
            <a permission="@Policies.CanModifyStoreSettings"
               layout-menu-item="MakePayPayments"
               asp-controller="MakePay"
               asp-action="Payments"
               asp-route-storeId="@storeId">
                <span>Payments</span>
            </a>
        </li>
        <li class="nav-item nav-item-sub">
            <a permission="@Policies.CanModifyStoreSettings"
               layout-menu-item="MakePayGeneral"
               asp-controller="MakePay"
               asp-action="General"
               asp-route-storeId="@storeId">
                <span>Settings</span>
            </a>
        </li>
        <li class="nav-item nav-item-sub">
            <a permission="@Policies.CanModifyStoreSettings"
               layout-menu-item="MakePayCurrencies"
               asp-controller="MakePay"
               asp-action="AllowedCurrencies"
               asp-route-storeId="@storeId">
                <span>Allowed currencies</span>
            </a>
        </li>
        <li class="nav-item nav-item-sub">
            <a permission="@Policies.CanModifyStoreSettings"
               layout-menu-item="MakePaySettlement"
               asp-controller="MakePay"
               asp-action="Settlement"
               asp-route-storeId="@storeId">
                <span>Settlement</span>
            </a>
        </li>
    }
}
